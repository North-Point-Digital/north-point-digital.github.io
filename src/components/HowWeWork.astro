---
const steps = [
  {
    title: 'A short call',
    description:
      'Thirty minutes, no pitch deck. We work out together whether there is a fit and where the value would be.',
    icon: 'M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z',
  },
  {
    title: 'Assessment',
    description:
      'We look at your AWS estate, your data and the use case, then send a written scope with a fixed price.',
    icon: 'M11 19a8 8 0 100-16 8 8 0 000 16zM21 21l-4.35-4.35',
  },
  {
    title: 'Fixed-fee delivery',
    description:
      'Six weeks for an AI Launchpad, two for a Blueprint review. Weekly demos, so you see progress, not promises.',
    icon: 'M16 18l6-6-6-6M8 6l-6 6 6 6',
  },
  {
    title: 'Handover',
    description:
      'Documentation, knowledge transfer and 30 days of support. No lock-in; the aim is to leave you self-sufficient.',
    icon: 'M16.5 9.4l-9-5.19M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16zM3.27 6.96L12 12.01l8.73-5.05M12 22.08V12',
  },
];
---

<section id="how-we-work" class="section bg-white">
  <div class="container-site">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">How we work</p>
      <h2 class="text-h2">From first call to handover</h2>
      <p class="mt-4 text-lg text-slate-600">
        Every engagement runs the same way. You'll know the price and the timeline
        before any work starts.
      </p>
    </div>

    <ol class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4" data-reveal>
      {steps.map((step, i) => (
        <li class="relative">
          <div class="card h-full">
            <div class="flex items-center justify-between">
              <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-accent-tint">
                <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d={step.icon} />
                </svg>
              </div>
              <span class="font-mono text-sm font-medium text-slate-400">0{i + 1}</span>
            </div>
            <h3 class="mt-5 text-lg font-semibold text-slate-900">{step.title}</h3>
            <p class="mt-2 text-[0.95rem] leading-relaxed text-slate-600">{step.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
