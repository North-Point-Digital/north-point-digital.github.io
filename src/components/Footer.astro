<script>
  document.querySelectorAll('[data-track-external]').forEach((el) => {
    el.addEventListener('click', () => {
      const url = (el as HTMLElement).dataset.trackExternal;
      const label = (el as HTMLElement).dataset.trackLabel;
      if (typeof window.gtag === 'function' && url) {
        window.gtag('event', 'external_link_click', {
          event_category: 'outbound',
          event_label: label || url,
          link_url: url,
          link_text: label,
        });
      }
    });
  });

  document.querySelectorAll('[data-track-nav]').forEach((el) => {
    el.addEventListener('click', () => {
      const linkName = (el as HTMLElement).dataset.trackNav;
      const href = (el as HTMLAnchorElement).href;
      if (typeof window.gtag === 'function' && linkName) {
        window.gtag('event', 'navigation_click', {
          event_category: 'navigation',
          event_label: linkName,
          link_name: linkName,
          destination: href,
        });
      }
    });
  });
</script>
