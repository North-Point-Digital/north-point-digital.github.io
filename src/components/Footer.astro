---
const year = new Date().getFullYear();

const quickLinks = [
  { name: 'Services', href: '/#services' },
  { name: 'How we work', href: '/#how-we-work' },
  { name: 'Case studies', href: '/#case-studies' },
  { name: 'Blog', href: '/blog' },
  { name: 'Contact', href: '/contact' },
];

const serviceLinks = [
  { name: 'AI Launchpad', href: '/ai-launchpad' },
  { name: 'Cost & security blueprint', href: '/aws-cost-optimisation' },
  { name: 'Build better on AWS', href: '/build-better' },
  { name: 'AI Adoption Playbook', href: '/ai-adoption-playbook' },
];
---

<footer class="bg-slate-900 text-slate-300">
  <div class="container-site grid grid-cols-1 gap-12 py-16 md:grid-cols-[2fr_1fr_1fr]">
    <div>
      <a href="/" class="flex items-center gap-2.5 no-underline">
        <img src="/north-point-logo.webp" alt="" width="36" height="36" class="h-9 w-9" loading="lazy" />
        <span class="text-lg font-semibold text-white">North Point Digital</span>
      </a>
      <p class="mt-4 max-w-sm leading-relaxed text-slate-400">
        We help small businesses put AI to work — whatever systems they run — and
        help AWS customers spend less on their cloud. Fixed fees, no long contracts.
      </p>
      <div class="mt-6 flex gap-3">
        <a
          href="https://x.com/n0rth_p0int"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="X (Twitter)"
          class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/5 text-slate-300 transition-colors duration-fast hover:bg-white/10 hover:text-white"
          data-track-external="https://x.com/n0rth_p0int"
          data-track-label="X (Twitter)"
        >
          <svg class="h-4.5 w-4.5 fill-current" width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/company/north-point-digital-ai/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/5 text-slate-300 transition-colors duration-fast hover:bg-white/10 hover:text-white"
          data-track-external="https://www.linkedin.com/company/north-point-digital-ai/"
          data-track-label="LinkedIn"
        >
          <svg class="h-4.5 w-4.5 fill-current" width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
      </div>
    </div>

    <nav aria-label="Site">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Explore</h2>
      <ul class="mt-4 space-y-2.5">
        {quickLinks.map((link) => (
          <li>
            <a href={link.href} class="text-slate-300 no-underline transition-colors duration-fast hover:text-white" data-track-nav={link.name}>
              {link.name}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <nav aria-label="Services">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-500">Services</h2>
      <ul class="mt-4 space-y-2.5">
        {serviceLinks.map((link) => (
          <li>
            <a href={link.href} class="text-slate-300 no-underline transition-colors duration-fast hover:text-white" data-track-nav={link.name}>
              {link.name}
            </a>
          </li>
        ))}
        <li>
          <a href="mailto:contact@northpointdigital.com" class="text-slate-300 no-underline transition-colors duration-fast hover:text-white">
            contact@northpointdigital.com
          </a>
        </li>
      </ul>
    </nav>
  </div>

  <div class="border-t border-white/10">
    <div class="container-site flex flex-col gap-3 py-6 text-sm text-slate-500 md:flex-row md:items-center md:justify-between">
      <p>
        {/* TODO(David): replace with registered company name, number and registered office. */}
        © {year} North Point Digital. Registered in England &amp; Wales, company no. 00000000.
        Registered office: [registered office address].
      </p>
      <a href="/privacy-policy" class="text-slate-400 no-underline transition-colors duration-fast hover:text-white">Privacy policy</a>
    </div>
  </div>
</footer>
