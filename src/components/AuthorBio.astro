---
import { getAuthor } from '../data/authors';

interface Props {
  author: string;
}

const { author } = Astro.props;
const a = getAuthor(author);
---

<aside class="mt-14 flex flex-col gap-5 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:flex-row sm:items-center sm:p-8">
  {a.image && (
    <img
      src={a.image}
      alt={a.name}
      width="80"
      height="80"
      loading="lazy"
      class="h-20 w-20 shrink-0 rounded-full border border-slate-200 object-cover"
    />
  )}
  <div>
    <p class="text-xs font-medium uppercase tracking-wider text-slate-500">Written by</p>
    <p class="mt-1 text-lg font-semibold text-slate-900">{a.name}</p>
    {a.role && <p class="text-sm text-slate-500">{a.role}</p>}
    {a.bio && <p class="mt-3 text-[0.95rem] leading-relaxed text-slate-600">{a.bio}</p>}
  </div>
</aside>
