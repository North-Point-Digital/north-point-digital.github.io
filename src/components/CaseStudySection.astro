---
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('caseStudies');
---

<section id="case-studies" class="section bg-slate-50">
  <div class="container-site">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">Case studies</p>
      <h2 class="text-h2">Real engagements, with numbers</h2>
      <p class="mt-4 text-lg text-slate-600">
        How we've helped clients cut costs, tighten security and ship faster.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3" data-reveal>
      {caseStudies.map((cs) => (
        <a
          href={`/case-studies/${cs.slug}`}
          class="card card-hover group flex flex-col no-underline"
          data-track-cta={`Case Study: ${cs.data.clientName}`}
        >
          <div class="flex items-center gap-4">
            {cs.data.logo && (
              <img
                src={cs.data.logo}
                alt=""
                width="48"
                height="48"
                loading="lazy"
                class="h-12 w-12 rounded-lg border border-slate-200 bg-white object-contain p-1.5"
              />
            )}
            <div>
              <h3 class="text-lg font-semibold text-slate-900">{cs.data.clientName}</h3>
              {cs.data.industry && <p class="text-sm text-slate-500">{cs.data.industry}</p>}
            </div>
          </div>

          <p class="mt-5 leading-relaxed text-slate-600">{cs.data.challenge}</p>

          {cs.data.results.length > 0 && (
            <ul class="mt-5 space-y-2 border-t border-slate-200 pt-5">
              {cs.data.results.slice(0, 3).map((result) => (
                <li class="flex items-start gap-2.5 text-[0.95rem] text-slate-700">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6L9 17l-5-5" />
                  </svg>
                  {result}
                </li>
              ))}
            </ul>
          )}

          <span class="mt-auto pt-6 font-semibold text-accent transition-colors duration-fast group-hover:text-accent-hover">
            Read the full case study →
          </span>
        </a>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <p class="text-lg text-slate-600">Facing something similar?</p>
      <a
        href="https://calendly.com/david-northpointdigital/north-point-digital-initial-call"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
        data-track-cta="Case Studies Book a Call"
      >
        Book a free call
      </a>
    </div>
  </div>
</section>
