---
import CalendlyCTA from './CalendlyCTA.astro';
import { getCollection } from 'astro:content';

const caseStudies = await getCollection('caseStudies');
---

<section id="case-studies" class="section-padding relative overflow-hidden">
  <div class="container-wide">
    <div class="text-center mb-16">
      <h2 class="text-h2 text-white mb-4">Case Studies</h2>
      <p class="text-xl text-white/80 max-w-[600px] mx-auto">Real results from real clients. See how we've helped businesses reduce costs, improve security, and accelerate innovation.</p>
    </div>

    <div class="grid gap-8 grid-cols-1 md:grid-cols-2 lg:grid-cols-3 opacity-0" data-animate-on-scroll>
      {caseStudies.map((cs) => (
        <div class="glass-card p-10 relative flex flex-col cursor-pointer [&:hover_.read-more]:translate-x-[5px]">
          <a href={`/case-studies/${cs.slug}`} class="no-underline text-inherit flex flex-col h-full" data-track-cta={`Case Study: ${cs.data.clientName}`}>
            <div class="flex items-center gap-4 mb-6">
              {cs.data.logo && (
                <img src={cs.data.logo} alt={`${cs.data.clientName} logo`} loading="lazy" class="w-[60px] h-[60px] object-contain rounded-lg bg-white/10 p-2" />
              )}
              <div class="flex-1">
                <h3 class="text-white text-2xl mb-1">{cs.data.clientName}</h3>
                {cs.data.industry && <p class="text-white/70 text-sm">{cs.data.industry}</p>}
              </div>
            </div>

            <div class="mb-6">
              <h4 class="text-white/90 text-base mb-2 font-semibold">Challenge</h4>
              <p class="text-white/80 leading-relaxed text-[0.95rem]">{cs.data.challenge}</p>
            </div>

            <div class="mb-6">
              <h4 class="text-white/90 text-base mb-2 font-semibold">Solution</h4>
              <p class="text-white/80 leading-relaxed text-[0.95rem]">{cs.data.solution}</p>
            </div>

            <div class="mt-auto pt-6 border-t border-white/10">
              <h4 class="text-white/90 text-base mb-4 font-semibold">Results</h4>
              <ul class="list-none p-0 m-0">
                {cs.data.results.map((result) => (
                  <li class="text-white/90 py-2 text-[0.95rem]">{result}</li>
                ))}
              </ul>
            </div>

            <div class="read-more mt-6 pt-6 border-t border-white/10 flex items-center gap-2 text-white/90 font-semibold text-[0.95rem] transition-all duration-300">
              Read Full Case Study →
            </div>
          </a>
        </div>
      ))}
    </div>

    <CalendlyCTA />
  </div>
</section>
