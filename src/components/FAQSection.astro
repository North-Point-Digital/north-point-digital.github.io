---
import { faqs } from '../data/faqs';

interface Props {
  framed?: boolean;
}

const { framed = false } = Astro.props;
---

<section class="section bg-white" id={framed ? undefined : 'faq'} data-section="faq">
  <div class="container-site max-w-3xl">
    <div class="text-center">
      <p class="eyebrow mb-4">FAQ</p>
      <h2 class="text-h2">Questions we hear a lot</h2>
    </div>

    <div class="mt-12 flex flex-col gap-3" data-faq-container>
      {faqs.map((faq, index) => (
        <details
          class="group rounded-xl border border-slate-200 bg-white open:shadow-sm"
          open={index === 0}
          data-faq-question={faq.question}
        >
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5 text-left font-semibold text-slate-900 [&::-webkit-details-marker]:hidden">
            {faq.question}
            <svg
              class="h-5 w-5 shrink-0 text-slate-400 transition-transform duration-fast group-open:rotate-180"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M6 9l6 6 6-6" />
            </svg>
          </summary>
          <div
            class="px-5 pb-5 leading-relaxed text-slate-600 [&_p]:mb-4 [&_p:last-child]:mb-0 [&_strong]:font-semibold [&_strong]:text-slate-900 [&_ul]:my-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ul_li]:py-1"
            set:html={faq.answer}
          />
        </details>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll('[data-faq-question]').forEach(function (el) {
    el.addEventListener('toggle', function () {
      if (el.open && typeof window.gtag === 'function') {
        window.gtag('event', 'faq_open', {
          event_category: 'engagement',
          event_label: el.dataset.faqQuestion,
          question: el.dataset.faqQuestion,
        });
      }
    });
  });
</script>
