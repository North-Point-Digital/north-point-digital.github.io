---
const examples = [
  {
    title: 'Answer the same questions, once',
    before: 'Your inbox fills with the same twenty questions every week.',
    after: 'An assistant drafts each reply from your past answers. Your team checks and sends.',
    icon: 'M4 4h16v12H5.17L4 17.17V4zM8 9h8M8 13h5',
  },
  {
    title: 'Paperwork that types itself',
    before: 'Someone retypes invoices, delivery notes and contracts into the system.',
    after: 'Amounts, dates and terms land in your spreadsheet or accounts package on their own.',
    icon: 'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8',
  },
  {
    title: 'Ask your own documents',
    before: 'The answer is in a manual, a policy or an old proposal. Somewhere.',
    after: 'Ask in plain English, get the answer back with the source it came from.',
    icon: 'M11 19a8 8 0 100-16 8 8 0 000 16zM21 21l-4.35-4.35',
  },
  {
    title: 'Quotes built on past jobs',
    before: 'Estimates start from a blank page and whoever wrote the last one.',
    after: 'A draft quote based on what similar jobs actually cost you, ready to adjust.',
    icon: 'M9 7h6m-6 4h6m-6 4h4M5 3h14a1 1 0 011 1v17l-3-2-3 2-3-2-3 2-3-2V4a1 1 0 011-1z',
  },
  {
    title: 'Notes that file themselves',
    before: 'Call notes live in notebooks and heads, and the CRM is always behind.',
    after: 'Meetings summarised and logged against the right customer, the same day.',
    icon: 'M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z',
  },
  {
    title: 'Support that sorts itself',
    before: 'Every ticket waits in one queue until someone reads it.',
    after: 'Tickets arrive sorted and routed, with a suggested reply already drafted.',
    icon: 'M22 12h-6l-2 3h-4l-2-3H2M5.45 5.11L2 12v6a2 2 0 002 2h16a2 2 0 002-2v-6l-3.45-6.89A2 2 0 0016.76 4H7.24a2 2 0 00-1.79 1.11z',
  },
];
---

<section id="examples" class="section bg-slate-50">
  <div class="container-site">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">Working examples</p>
      <h2 class="text-h2">What AI actually does in a small business</h2>
      <p class="mt-4 text-lg text-slate-600">
        Not robots, not magic. Just software that takes the repetitive part of a job
        and gives the hours back. These are the kinds of things a Launchpad proves.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3" data-reveal>
      {examples.map((example) => (
        <div class="card card-hover">
          <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-accent-tint">
            <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={example.icon} />
            </svg>
          </div>
          <h3 class="mt-5 text-lg font-semibold text-slate-900">{example.title}</h3>
          <p class="mt-3 text-[0.95rem] leading-relaxed text-slate-500">
            <span class="font-mono text-xs uppercase tracking-wider text-slate-400">Now&nbsp;&nbsp;</span>
            {example.before}
          </p>
          <p class="mt-2 text-[0.95rem] leading-relaxed text-slate-700">
            <span class="font-mono text-xs uppercase tracking-wider text-accent">With AI&nbsp;&nbsp;</span>
            {example.after}
          </p>
        </div>
      ))}
    </div>

    <p class="mx-auto mt-10 max-w-2xl text-center text-slate-600">
      Your systems stay where they are, whether that's on-prem, Microsoft, Google,
      or a folder of spreadsheets. We've built on AWS for a decade. You never have
      to log into it.
    </p>

    <div class="mt-8 flex flex-col items-center gap-3">
      <a
        href="https://calendly.com/david-northpointdigital/north-point-digital-initial-call"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
        data-track-cta="Examples Book a Call"
      >
        Sound like your week? Book a free call
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
      <a href="/ai-launchpad" class="text-sm font-medium text-slate-500 no-underline hover:text-slate-700" data-track-cta="Examples Explore Launchpad">
        or see how a six-week Launchpad proves one of these →
      </a>
    </div>
  </div>
</section>
