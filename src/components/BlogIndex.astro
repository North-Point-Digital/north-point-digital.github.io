---
import type { Page } from 'astro';
import type { CollectionEntry } from 'astro:content';

interface Category {
  name: string;
  slug: string;
  count: number;
}

interface Props {
  page: Page<CollectionEntry<'blog'>>;
  categories: Category[];
  activeCategory?: string;
}

const { page, categories, activeCategory } = Astro.props;

const heading = activeCategory
  ? categories.find((c) => c.slug === activeCategory)?.name
  : 'Notes from the field';
---

<section class="relative overflow-hidden bg-white pt-16">
  <div class="hero-tint" aria-hidden="true"></div>
  <div class="hero-dots" aria-hidden="true"></div>
  <div class="container-site relative py-20 md:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-6">Blog</p>
      <h1 class="text-h1">{heading}</h1>
      <p class="mt-6 text-lg leading-relaxed text-slate-600 md:text-xl">
        Practical articles on AI and the cloud it runs on, for people who'd rather
        have specifics than buzzwords.
      </p>
    </div>

    <nav class="mt-10 flex flex-wrap items-center justify-center gap-2" aria-label="Blog categories">
      <a
        href="/blog"
        class:list={[
          'rounded-full border px-4 py-1.5 text-sm font-medium no-underline transition-colors duration-fast',
          !activeCategory
            ? 'border-accent bg-accent text-white'
            : 'border-slate-300 bg-white text-slate-600 hover:border-slate-400 hover:text-slate-900',
        ]}
        aria-current={!activeCategory ? 'page' : undefined}
      >
        All
      </a>
      {categories.map((category) => (
        <a
          href={`/blog/category/${category.slug}`}
          class:list={[
            'rounded-full border px-4 py-1.5 text-sm font-medium no-underline transition-colors duration-fast',
            activeCategory === category.slug
              ? 'border-accent bg-accent text-white'
              : 'border-slate-300 bg-white text-slate-600 hover:border-slate-400 hover:text-slate-900',
          ]}
          aria-current={activeCategory === category.slug ? 'page' : undefined}
        >
          {category.name}
          <span class:list={['ml-1', activeCategory === category.slug ? 'text-white/70' : 'text-slate-400']}>{category.count}</span>
        </a>
      ))}
    </nav>

    <div class="mx-auto mt-12 grid max-w-6xl grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
      {page.data.map((post) => (
        <a href={`/blog/${post.slug}`} class="card card-hover group flex h-full flex-col overflow-hidden !p-0 no-underline">
          {post.data.thumbnailImage && (
            <img
              src={post.data.thumbnailImage}
              alt=""
              loading="lazy"
              width="600"
              height="200"
              class="h-[180px] w-full border-b border-slate-200 object-cover"
            />
          )}
          <div class="flex flex-1 flex-col p-7">
            <p class="text-sm text-slate-500">
              <span class="font-medium text-accent">{post.data.category}</span>
              {' · '}
              {new Date(post.data.publishDate).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}
            </p>
            <h2 class="mt-2 text-lg font-semibold leading-snug text-slate-900">{post.data.title}</h2>
            {post.data.excerpt && (
              <p class="mt-3 text-[0.95rem] leading-relaxed text-slate-600">{post.data.excerpt}</p>
            )}
            <span class="mt-auto pt-5 text-[0.95rem] font-semibold text-accent transition-colors duration-fast group-hover:text-accent-hover">
              Read the article →
            </span>
          </div>
        </a>
      ))}
    </div>

    {page.lastPage > 1 && (
      <nav class="mt-12 flex items-center justify-center gap-4" aria-label="Pagination">
        {page.url.prev ? (
          <a href={page.url.prev} class="btn-secondary !px-5 !py-2.5 text-sm">← Newer</a>
        ) : (
          <span class="inline-flex items-center rounded-lg border border-slate-200 px-5 py-2.5 text-sm font-semibold text-slate-300">← Newer</span>
        )}
        <span class="text-sm text-slate-500">Page {page.currentPage} of {page.lastPage}</span>
        {page.url.next ? (
          <a href={page.url.next} class="btn-secondary !px-5 !py-2.5 text-sm">Older →</a>
        ) : (
          <span class="inline-flex items-center rounded-lg border border-slate-200 px-5 py-2.5 text-sm font-semibold text-slate-300">Older →</span>
        )}
      </nav>
    )}

    <div class="mx-auto mt-14 max-w-5xl rounded-2xl border border-accent/30 bg-gradient-to-b from-accent-tint/60 to-white p-8 text-center md:p-10">
      <p class="eyebrow mb-3">Free download</p>
      <h2 class="text-2xl font-semibold tracking-tight text-slate-900">The AI Adoption Playbook</h2>
      <p class="mx-auto mt-3 max-w-xl text-slate-600">
        If you're reading up before making a move, start here: picking a use case,
        getting your data ready, and what AI actually costs to run.
      </p>
      <a href="/ai-adoption-playbook" class="btn-primary mt-6" data-track-cta="Blog Index Playbook">
        Get the playbook
      </a>
    </div>
  </div>
</section>
