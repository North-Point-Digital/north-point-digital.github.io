---
interface TeamMember {
  name: string;
  role: string;
  bio: string;
  image: string;
}

interface Props {
  teamMembers?: TeamMember[];
}

const { teamMembers = [] } = Astro.props;
---

<section id="team" class="section bg-slate-50">
  <div class="container-site">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">The team</p>
      <h2 class="text-h2">Who you'll be working with</h2>
      <p class="mt-4 text-lg text-slate-600">
        No bait and switch — the people on this page do the work.
      </p>
    </div>

    {teamMembers.length > 0 && (
      <ul class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal>
        {teamMembers.map((member) => (
          <li class="card flex items-start gap-5">
            <div class="h-20 w-20 shrink-0 overflow-hidden rounded-xl border border-slate-200 bg-slate-100">
              {member.image && member.image.trim() !== '' ? (
                <img
                  src={member.image}
                  alt={member.name}
                  width="80"
                  height="80"
                  loading="lazy"
                  class="h-full w-full object-cover"
                />
              ) : (
                <span class="flex h-full w-full items-center justify-center text-xl font-semibold text-slate-400">
                  {member.name.split(' ').map((n: string) => n[0]).join('')}
                </span>
              )}
            </div>
            <div>
              <h3 class="font-semibold text-slate-900">{member.name}</h3>
              <p class="mt-0.5 text-sm font-medium text-accent">{member.role}</p>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{member.bio}</p>
            </div>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>
