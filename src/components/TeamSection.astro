---
import CalendlyCTA from './CalendlyCTA.astro';

interface TeamMember {
  name: string;
  role: string;
  bio: string;
  image: string;
}

interface Props {
  teamMembers?: TeamMember[];
}

const { teamMembers = [] } = Astro.props;
---

<section id="team" class="section-padding bg-white relative">
  <div class="container-default">
    <div class="text-center mb-16">
      <h2 class="text-h2 text-[#333] mb-4">Our Team</h2>
      <p class="text-xl text-[#666] max-w-[600px] mx-auto">Meet the experts behind North Point Digital</p>
    </div>

    {teamMembers.length > 0 && (
      <div class="grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-12 mt-12 max-md:grid-cols-1 max-md:gap-10 opacity-0" data-animate-on-scroll>
        {teamMembers.map((member) => (
          <div class="text-center flex flex-col items-center">
            <div class="w-[200px] h-[200px] rounded-full overflow-hidden mb-6 border-4 border-[#f0f0f0] shadow-md transition-all duration-300 bg-gradient-primary flex items-center justify-center hover:scale-105 hover:shadow-lg max-md:w-[180px] max-md:h-[180px]">
              {member.image && member.image.trim() !== '' ? (
                <img src={member.image} alt={member.name} loading="lazy" class="w-full h-full object-contain object-center block" />
              ) : (
                <span class="text-white/70 text-3xl font-semibold">{member.name.split(' ').map((n: string) => n[0]).join('')}</span>
              )}
            </div>
            <h3 class="text-2xl text-[#333] mb-2 font-semibold">{member.name}</h3>
            <p class="text-base text-primary mb-4 font-medium">{member.role}</p>
            <p class="text-[0.95rem] text-[#666] leading-relaxed max-w-[300px] mx-auto">{member.bio}</p>
          </div>
        ))}
      </div>
    )}

    <CalendlyCTA />
  </div>
</section>
