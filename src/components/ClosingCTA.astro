---
interface Props {
  title?: string;
  subtitle?: string;
  calendly?: string;
}

const {
  title = "Bring us a use case. We'll tell you what it costs to prove.",
  subtitle = "A free 30-minute call with an engineer, not a salesperson. If there's no fit, we'll say so on the call.",
  calendly = 'https://calendly.com/david-northpointdigital/north-point-digital-initial-call',
} = Astro.props;
const CALENDLY = calendly;
---

<section id="contact" class="relative overflow-hidden bg-slate-900">
  <svg class="pointer-events-none absolute inset-0 h-full w-full opacity-[0.13]" aria-hidden="true">
    <defs>
      <pattern id="cta-nodes" width="120" height="120" patternUnits="userSpaceOnUse">
        <circle cx="20" cy="20" r="1.5" fill="#93c5fd" />
        <circle cx="80" cy="60" r="1.5" fill="#93c5fd" />
        <circle cx="40" cy="100" r="1.5" fill="#93c5fd" />
        <path d="M20 20L80 60L40 100" stroke="#3b82f6" stroke-width="0.5" fill="none" />
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#cta-nodes)" />
  </svg>
  <div class="container-site relative py-20 text-center md:py-28">
    <h2 class="mx-auto max-w-2xl text-h2 !text-white">{title}</h2>
    <p class="mx-auto mt-4 max-w-xl text-lg text-slate-400">{subtitle}</p>
    <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
      <a
        href={CALENDLY}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary"
        data-track-cta="Closing Book a Call"
      >
        Book a free call
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-600 px-6 py-3.5 text-base font-semibold text-white no-underline transition-colors duration-fast hover:border-slate-400 hover:bg-white/5"
        data-track-cta="Closing Contact"
      >
        Send us a message
      </a>
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-slate-400">
      <span class="flex items-center gap-2.5">
        <img src="/aws-logo.png" alt="Amazon Web Services" width="34" height="20" class="h-5 w-auto" loading="lazy" />
        Official AWS Partner
      </span>
      <span>20+ Well-Architected reviews completed</span>
      <span>Fixed fees · no long-term contracts</span>
    </div>
  </div>
</section>
