---
---

<section id="about" class="section bg-white">
  <div class="container-site grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
    <div>
      <p class="eyebrow mb-4">About us</p>
      <h2 class="text-h2">A small, senior team</h2>
      <div class="mt-5 space-y-5 text-lg leading-relaxed text-slate-600">
        <p>
          We're AWS-certified architects and engineers who've spent the last decade
          inside enterprise cloud estates — building them, migrating them, and finding
          out where the money goes.
        </p>
        <p>
          We work with the AWS frameworks that have earned their keep — Well-Architected
          Reviews, the Migration Acceleration Programme — and we charge fixed fees,
          because day rates reward slow work.
        </p>
        <p>
          AWS clients typically see around 35% off their cloud spend, with a stronger
          security posture to go with it. The AI work draws on the same engineering —
          pointed at your business, wherever your systems happen to live.
        </p>
      </div>
    </div>

    <div class="overflow-hidden rounded-2xl border border-slate-200 shadow-sm" data-reveal>
      <video
        controls
        playsinline
        preload="metadata"
        class="block h-auto w-full"
        data-track-video="About Us Video"
      >
        <source src="/about-video.mp4" type="video/mp4" />
        Your browser does not support the video tag.
      </video>
    </div>
  </div>
</section>

<script is:inline>
  document.querySelectorAll('[data-track-video]').forEach(function (video) {
    var name = video.dataset.trackVideo;
    function send(event) {
      if (typeof window.gtag === 'function') {
        window.gtag('event', event, { event_category: 'media', event_label: name, video_name: name });
      }
    }
    video.addEventListener('play', function () { send('video_play'); });
    video.addEventListener('pause', function () { send('video_pause'); });
    video.addEventListener('ended', function () { send('video_complete'); });
  });
</script>
