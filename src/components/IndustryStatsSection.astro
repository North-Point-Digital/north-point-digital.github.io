---
const stats = [
  {
    number: '16%',
    label: 'of UK businesses use any AI at all',
    description:
      'UK government research, February 2026. Your competitors haven’t started either — the advantage is still there for the taking.',
    icon: 'M23 6l-9.5 9.5-5-5L1 18M17 6h6v6',
  },
  {
    number: '6 weeks',
    label: 'from first call to working software',
    description:
      'One fixed fee, agreed before we start. A demo every week, and an honest answer at the end — even if that answer is "don’t proceed".',
    icon: 'M12 8v4l3 3M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
  },
  {
    number: '30–40%',
    label: 'recovered from a typical AWS bill',
    description:
      'Already on AWS? What our cost reviews usually find is enough to pay for the AI pilot outright. If you’re not, this simply doesn’t apply — the AI work doesn’t care where your systems live.',
    icon: 'M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6',
  },
];
---

<section class="section relative overflow-hidden bg-white">
  <div class="band-grid" aria-hidden="true"></div>
  <div class="container-site relative">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">Why now</p>
      <h2 class="text-h2">Your competitors haven't started either</h2>
      <p class="mt-4 text-lg text-slate-600">
        AI in small business is still rare. Moving first is cheaper than it looks —
        and for AWS customers, it often pays for itself.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-3" data-reveal>
      {stats.map((stat) => (
        <div class="card">
          <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-accent-tint">
            <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={stat.icon} />
            </svg>
          </div>
          <p class="mt-5 font-mono text-5xl font-semibold tracking-tight text-slate-900">{stat.number}</p>
          <p class="mt-3 font-semibold text-slate-900">{stat.label}</p>
          <p class="mt-2 text-[0.95rem] leading-relaxed text-slate-600">{stat.description}</p>
        </div>
      ))}
    </div>

    <p class="mt-8 text-center text-sm text-slate-500">
      Sources: GOV.UK, AWS, Gartner, IBM Security reports
    </p>
  </div>
</section>
