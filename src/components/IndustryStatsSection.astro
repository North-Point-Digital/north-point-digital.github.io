---
import CalendlyCTA from './CalendlyCTA.astro';

const stats = [
  { number: '78%', label: 'of companies overspend on AWS', description: 'Due to misconfiguration, over-provisioning, and lack of optimisation strategies' },
  { number: '80%', label: 'of data breaches', description: 'Are caused by infrastructure misconfigurations—preventable with proper security reviews' },
  { number: '30-40%', label: 'average cost savings identified', description: 'Through AWS Well-Architected Reviews by certified experts' },
];
---

<section class="section-padding bg-white/5 relative">
  <div class="container-default">
    <div class="text-center mb-16">
      <h2 class="text-h2 text-white mb-4">The Cloud Cost Crisis</h2>
      <p class="text-xl text-white/80 max-w-[700px] mx-auto">Industry data reveals massive waste and security risks in AWS infrastructure</p>
    </div>

    <div class="grid grid-cols-[repeat(auto-fit,minmax(300px,1fr))] gap-8 mt-12 opacity-0" data-animate-on-scroll>
      {stats.map((stat) => (
        <div class="glass-card text-center p-10">
          <div class="text-[3.5rem] font-bold text-white mb-2 leading-none">{stat.number}</div>
          <div class="text-lg text-white/90 mb-4 font-semibold">{stat.label}</div>
          <p class="text-[0.95rem] text-white/70 leading-relaxed">{stat.description}</p>
        </div>
      ))}
    </div>

    <div class="text-center mt-12 text-sm text-white/60 italic">
      Sources: AWS, Gartner, IBM Security Reports
    </div>

    <CalendlyCTA />
  </div>
</section>
