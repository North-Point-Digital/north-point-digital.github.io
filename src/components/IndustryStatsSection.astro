---
const stats = [
  {
    number: '16%',
    label: 'of UK businesses use any AI at all',
    description:
      'UK government research, February 2026. Early movers are still early — the competitive gap is wide open.',
  },
  {
    number: '78%',
    label: 'of companies overspend on AWS',
    description:
      'Mostly misconfiguration and over-provisioning. That is budget your AI work could be using instead.',
  },
  {
    number: '30–40%',
    label: 'typical savings found in a Well-Architected review',
    description:
      'Identified by certified reviewers — often enough to pay for a proof of concept outright.',
  },
];
---

<section class="section bg-white">
  <div class="container-site">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">Why now</p>
      <h2 class="text-h2">The numbers favour early movers</h2>
      <p class="mt-4 text-lg text-slate-600">
        AI adoption is still rare, and most AWS estates leak enough money to pay for it.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-3" data-reveal>
      {stats.map((stat) => (
        <div class="card">
          <p class="font-mono text-5xl font-semibold tracking-tight text-slate-900">{stat.number}</p>
          <p class="mt-3 font-semibold text-slate-900">{stat.label}</p>
          <p class="mt-2 text-[0.95rem] leading-relaxed text-slate-600">{stat.description}</p>
        </div>
      ))}
    </div>

    <p class="mt-8 text-center text-sm text-slate-500">
      Sources: GOV.UK, AWS, Gartner, IBM Security reports
    </p>
  </div>
</section>
