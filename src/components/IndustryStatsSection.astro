---
const stats = [
  {
    number: '78%',
    label: 'of companies overspend on AWS',
    description:
      'Misconfiguration and over-provisioning, mostly. Money out the door every month, buying nothing.',
    icon: 'M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6',
  },
  {
    number: '30–40%',
    label: 'of spend recovered in a typical review',
    description:
      'What certified reviewers find in a Well-Architected review. On most bills, that pays for an AI pilot outright.',
    icon: 'M22 12h-4l-3 9L9 3l-3 9H2',
  },
  {
    number: '16%',
    label: 'of UK businesses use any AI at all',
    description:
      'UK government research, February 2026. Your competitors haven’t started either — yet.',
    icon: 'M23 6l-9.5 9.5-5-5L1 18M17 6h6v6',
  },
];
---

<section class="section bg-white">
  <div class="container-site">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">Why now</p>
      <h2 class="text-h2">Most AWS bills leak enough to fund an AI pilot</h2>
      <p class="mt-4 text-lg text-slate-600">
        That's the whole pitch: we find the waste, fix the risks, and put the
        difference to work — while most of the market is still writing strategy decks.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-3" data-reveal>
      {stats.map((stat) => (
        <div class="card">
          <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-accent-tint">
            <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={stat.icon} />
            </svg>
          </div>
          <p class="mt-5 font-mono text-5xl font-semibold tracking-tight text-slate-900">{stat.number}</p>
          <p class="mt-3 font-semibold text-slate-900">{stat.label}</p>
          <p class="mt-2 text-[0.95rem] leading-relaxed text-slate-600">{stat.description}</p>
        </div>
      ))}
    </div>

    <p class="mt-8 text-center text-sm text-slate-500">
      Sources: GOV.UK, AWS, Gartner, IBM Security reports
    </p>
  </div>
</section>
