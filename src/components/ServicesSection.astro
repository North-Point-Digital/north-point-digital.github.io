---
const CALENDLY = 'https://calendly.com/david-northpointdigital/north-point-digital-initial-call';

const supportingServices = [
  {
    title: 'Cut your AWS bill',
    name: 'Security & Cost Optimisation Blueprint',
    description:
      'A two-week Well-Architected review of the pillars that pay for themselves: cost and security. We fix critical issues while we’re in there — and if we don’t find 25% in savings, you don’t pay.',
    features: ['No savings found, no fee', 'Security fixes included', 'Report and roadmap in two weeks'],
    link: '/aws-profitability-resilience-blueprint',
    trackName: 'Save Money',
    icon: 'M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6',
  },
  {
    title: 'Foundations that hold up',
    name: 'Build Better on AWS',
    description:
      'Architecture, migrations, landing zones and DevOps — with AWS MAP funding where your workload qualifies. For teams that want deployments to be boring.',
    features: ['Cloud migrations & MAP funding', 'Landing zones & governance', 'DevOps & SRE'],
    link: '/build-better',
    trackName: 'Build Better',
    mra: true,
    icon: 'M2 20h20M4 20V8l8-5 8 5v12M9 20v-6h6v6',
  },
];
---

<section id="services" class="section bg-slate-50">
  <div class="container-site">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow mb-4">Services</p>
      <h2 class="text-h2">What we do</h2>
      <p class="mt-4 text-lg text-slate-600">
        Three offers, each with a fixed scope and a clear deliverable.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-6 lg:grid-cols-2" data-reveal>
      {/* Flagship: AI Launchpad */}
      <article class="card card-hover relative flex flex-col border-accent/30 bg-gradient-to-b from-accent-tint/60 to-white lg:row-span-1 lg:col-span-2 lg:p-10">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-start">
          <div class="flex-1">
            <p class="eyebrow mb-3">Flagship · AI Launchpad</p>
            <h3 class="text-2xl font-semibold text-slate-900">Ship working AI in six weeks</h3>
            <p class="mt-3 max-w-xl leading-relaxed text-slate-600">
              A fixed-fee proof of concept built with your data. We run it on cloud
              infrastructure we manage — you don't need to be on AWS, or ever log
              into it. Weekly demos while we build. At the end: software you can
              try, with the running costs attached.
            </p>
            <ul class="mt-5 grid grid-cols-1 gap-2.5 sm:grid-cols-2">
              {['Working prototype on your data', 'Production cost projections', 'Implementation roadmap', 'Fixed fee, six weeks'].map((f) => (
                <li class="flex items-start gap-2.5 text-[0.95rem] text-slate-700">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6L9 17l-5-5" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <div class="mt-7 flex flex-wrap gap-3">
              <a href="/ai-launchpad" class="btn-primary" data-track-service="Go Faster">
                Explore AI Launchpad
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
              <a href={CALENDLY} target="_blank" rel="noopener noreferrer" class="btn-secondary" data-track-cta="Services Book a Call">
                Talk it through first
              </a>
            </div>
          </div>

          {/* Simple data-flow diagram, drawn not stocked */}
          <svg class="mx-auto w-full max-w-[300px] shrink-0 text-slate-300 lg:mx-0" viewBox="0 0 300 220" fill="none" aria-hidden="true">
            <rect x="10" y="20" width="110" height="40" rx="8" stroke="currentColor" stroke-width="1.5" />
            <text x="65" y="44" text-anchor="middle" class="fill-slate-500" font-size="12" font-family="ui-monospace, monospace">Your data</text>
            <rect x="10" y="160" width="110" height="40" rx="8" stroke="currentColor" stroke-width="1.5" />
            <text x="65" y="184" text-anchor="middle" class="fill-slate-500" font-size="12" font-family="ui-monospace, monospace">Your use case</text>
            <rect x="180" y="90" width="110" height="40" rx="8" stroke="#2563eb" stroke-width="1.5" />
            <text x="235" y="114" text-anchor="middle" fill="#2563eb" font-size="12" font-family="ui-monospace, monospace">Working PoC</text>
            <path d="M120 40 C 160 40, 160 110, 180 110" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 4" />
            <path d="M120 180 C 160 180, 160 110, 180 110" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 4" />
            <text x="235" y="150" text-anchor="middle" class="fill-slate-400" font-size="11" font-family="ui-monospace, monospace">6 weeks · fixed fee</text>
          </svg>
        </div>
      </article>

      {supportingServices.map((service) => (
        <article class="card card-hover flex flex-col">
          <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-lg bg-accent-tint">
            <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={service.icon} />
            </svg>
          </div>
          <p class="eyebrow mb-3">{service.name}</p>
          <h3 class="text-xl font-semibold text-slate-900">{service.title}</h3>
          <p class="mt-3 leading-relaxed text-slate-600">{service.description}</p>
          <ul class="mt-5 space-y-2.5">
            {service.features.map((feature) => (
              <li class="flex items-start gap-2.5 text-[0.95rem] text-slate-700">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
          <div class="mt-auto flex flex-wrap items-center gap-4 pt-7">
            <a href={service.link} class="font-semibold text-accent no-underline transition-colors duration-fast hover:text-accent-hover" data-track-service={service.trackName}>
              Learn more →
            </a>
            {service.mra && (
              <a
                href="https://mra.northpointdigital.com"
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm font-medium text-slate-500 underline decoration-slate-300 underline-offset-4 transition-colors duration-fast hover:text-slate-700"
              >
                Try the Migration Readiness Assessment
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
