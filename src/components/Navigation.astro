---
const navItems = [
  { name: 'Services', path: '/#services' },
  { name: 'How we work', path: '/#how-we-work' },
  { name: 'Case studies', path: '/#case-studies' },
  { name: 'Blog', path: '/blog' },
];

const pathname = Astro.url.pathname;
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
  <nav class="container-site flex h-16 items-center justify-between" aria-label="Main">
    <a href="/" class="flex items-center gap-2.5 no-underline" data-track-nav="Home">
      <img src="/north-point-logo.webp" alt="" width="36" height="36" class="h-9 w-9" loading="eager" />
      <span class="text-[1.05rem] font-semibold tracking-tight text-slate-900">North Point Digital</span>
    </a>

    <ul class="hidden items-center gap-7 md:flex">
      {navItems.map((item) => (
        <li>
          <a
            href={item.path}
            class:list={[
              'text-[0.95rem] font-medium no-underline transition-colors duration-fast hover:text-slate-900',
              pathname.startsWith('/blog') && item.path === '/blog' ? 'text-slate-900' : 'text-slate-600',
            ]}
            data-track-nav={item.name}
          >
            {item.name}
          </a>
        </li>
      ))}
      <li>
        <a
          href="https://calendly.com/david-northpointdigital/north-point-digital-initial-call"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary !px-5 !py-2.5 text-sm"
          data-track-cta="Nav Book a Call"
        >
          Book a free call
        </a>
      </li>
    </ul>

    <button
      type="button"
      class="flex h-11 w-11 items-center justify-center rounded-lg text-slate-700 hover:bg-slate-100 md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
      data-menu-toggle
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path class="menu-open-icon" d="M4 7h16M4 12h16M4 17h16" />
        <path class="menu-close-icon hidden" d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-slate-200 bg-white md:hidden">
    <ul class="container-site flex flex-col gap-1 py-4">
      {navItems.map((item) => (
        <li>
          <a
            href={item.path}
            class="block rounded-lg px-3 py-3 text-base font-medium text-slate-700 no-underline hover:bg-slate-50 hover:text-slate-900"
            data-track-nav={item.name}
          >
            {item.name}
          </a>
        </li>
      ))}
      <li class="mt-2 px-3">
        <a
          href="https://calendly.com/david-northpointdigital/north-point-digital-initial-call"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary w-full"
          data-track-cta="Nav Book a Call"
        >
          Book a free call
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-menu-toggle]');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    toggle.setAttribute('aria-label', open ? 'Open menu' : 'Close menu');
    menu?.classList.toggle('hidden', open);
    toggle.querySelector('.menu-open-icon')?.classList.toggle('hidden', !open);
    toggle.querySelector('.menu-close-icon')?.classList.toggle('hidden', open);
  });
  menu?.querySelectorAll('a').forEach((link) =>
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      menu.classList.add('hidden');
      toggle?.querySelector('.menu-open-icon')?.classList.remove('hidden');
      toggle?.querySelector('.menu-close-icon')?.classList.add('hidden');
    })
  );
</script>
