---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSection from '../components/FAQSection.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import { buildFaqJsonLd } from '../data/faqs';

const CTA_LINK = 'https://calendly.com/david-northpointdigital/north-point-digital-initial-call';
const siteUrl = 'https://northpointdigital.com';

const capabilities = [
  { title: 'Scalable infrastructure', description: 'AWS foundations that grow with the business instead of against it.' },
  { title: 'Cloud migrations', description: 'Proven frameworks, including the AWS Migration Acceleration Program (MAP).' },
  { title: 'Landing zones', description: 'Multi-account architecture with security and governance built in from day one.' },
  { title: 'DevOps & SRE', description: 'CI/CD pipelines, infrastructure as code, and operations that hold up under load.' },
  { title: 'Solutions architecture', description: 'Designs reviewed against the Well-Architected Framework, not habit.' },
  { title: 'Modernisation', description: 'Legacy systems moved to cloud-native services a piece at a time, safely.' },
];

const details = [
  {
    title: 'Cloud migrations',
    content:
      "Moving to AWS doesn't have to be a leap of faith. We plan migrations in phases, keep downtime to a minimum, and use AWS MAP funding where your workload qualifies.",
    items: [
      'Assessment and planning to pick the right migration strategy',
      'Phased execution with minimal downtime',
      'Modernisation along the way where it pays for itself',
      'Post-migration optimisation and support',
    ],
  },
  {
    title: 'Landing zones & multi-account architecture',
    content:
      'A good landing zone is the difference between a cloud estate you govern and one that governs you. We design multi-account AWS Organisations with security, cost controls and provisioning automated from the start.',
    items: [
      'Multi-account AWS Organisation structure',
      'Centralised security and compliance controls',
      'Automated account provisioning and governance',
      'Cost allocation and budget management',
    ],
  },
  {
    title: 'DevOps & site reliability engineering',
    content:
      'Deployments should be boring. We build CI/CD pipelines, write the infrastructure as code, and set up the monitoring so that releases stop being events.',
    items: [
      'CI/CD pipeline design and implementation',
      'Infrastructure as code (Terraform, CloudFormation, CDK)',
      'Monitoring, alerting and observability',
      'Automated testing and deployment strategies',
    ],
  },
  {
    title: 'Solutions architecture',
    content:
      'Every estate carries different constraints. We design AWS architectures around yours: performance, security and cost together, not traded off by accident.',
    items: [
      'Requirements analysis and architecture design',
      'High availability and disaster recovery planning',
      'Security-first design principles',
      'Performance and scaling strategies',
    ],
  },
];
---

<BaseLayout
  title="Build Better on AWS: Architecture, Migrations & Modernisation | North Point Digital"
  description="AWS architecture, migrations, landing zones, DevOps, and modernisation services to help you build scalable, secure, and resilient cloud platforms."
  canonical="https://northpointdigital.com/build-better"
  breadcrumbs={[{ name: 'Home', url: siteUrl }, { name: 'Services', url: `${siteUrl}/#services` }, { name: 'Build Better', url: `${siteUrl}/build-better` }]}
  jsonLd={[
    { "@context": "https://schema.org", "@type": "Service", name: "Build Better on AWS", description: "AWS architecture, migrations, landing zones, DevOps, and modernisation services.", url: `${siteUrl}/build-better`, provider: { "@type": "Organization", name: "North Point Digital", url: `${siteUrl}/` }, areaServed: { "@type": "Country", name: "United Kingdom" }, serviceType: "AWS Architecture, Migration and Modernisation Consulting" },
    buildFaqJsonLd(),
  ]}
>
  <section class="relative overflow-hidden bg-white pt-16">
    <div class="hero-tint" aria-hidden="true"></div>
    <div class="hero-dots" aria-hidden="true"></div>
    <div class="container-site relative flex flex-col items-center py-20 text-center md:py-28">
      <p class="eyebrow mb-6">Architecture · Migration · Modernisation</p>
      <h1 class="max-w-4xl text-h1">Build better on AWS</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 md:text-xl">
        Architecture, migrations and modernisation for teams that need AWS done
        properly. Built to the Well-Architected Framework, priced before we start.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href={CTA_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary" data-track-cta="Build Better Book a Call">
          Book a free call
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
        <a
          href="https://mra.northpointdigital.com"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
          data-track-cta="Migration Readiness Assessment"
        >
          Try the Migration Readiness Assessment
        </a>
      </div>

      {/* The stack, bottom up */}
      <svg class="mt-16 w-full max-w-md" viewBox="0 0 440 200" fill="none" aria-hidden="true">
        <g font-family="ui-monospace, monospace">
          <rect x="40" y="148" width="360" height="40" rx="8" fill="#eff6ff" stroke="#2563eb" stroke-width="1.5" />
          <text x="220" y="172" text-anchor="middle" fill="#2563eb" font-size="12" font-weight="600">landing zone · accounts · governance</text>
          <rect x="70" y="98" width="300" height="40" rx="8" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.5" />
          <text x="220" y="122" text-anchor="middle" fill="#475569" font-size="12">pipelines · infrastructure as code</text>
          <rect x="100" y="48" width="240" height="40" rx="8" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.5" />
          <text x="220" y="72" text-anchor="middle" fill="#475569" font-size="12">your applications</text>
          <text x="220" y="24" text-anchor="middle" fill="#94a3b8" font-size="11">built from the bottom up, so the top stays up</text>
        </g>
      </svg>
    </div>
  </section>

  <section class="section border-t border-slate-200 bg-slate-50">
    <div class="container-site">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-4">What we build</p>
        <h2 class="text-h2">Infrastructure that's built to last</h2>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal>
        {capabilities.map((c) => (
          <div class="card">
            <h3 class="text-lg font-semibold text-slate-900">{c.title}</h3>
            <p class="mt-2 leading-relaxed text-slate-600">{c.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-site max-w-4xl space-y-6">
      {details.map((d) => (
        <article class="card lg:p-10">
          <h2 class="text-xl font-semibold text-slate-900">{d.title}</h2>
          <p class="mt-3 leading-relaxed text-slate-600">{d.content}</p>
          <ul class="mt-5 grid grid-cols-1 gap-2.5 sm:grid-cols-2">
            {d.items.map((item) => (
              <li class="flex items-start gap-2.5 text-[0.95rem] text-slate-700">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <FAQSection framed />

  <ClosingCTA
    title="Planning a migration or a rebuild?"
    subtitle="Book a free call, or run the Migration Readiness Assessment first and bring the results."
    calendly={CTA_LINK}
  />
</BaseLayout>
