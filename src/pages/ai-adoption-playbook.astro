---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteUrl = 'https://northpointdigital.com';

const contents = [
  'Pick the job, not the technology, with six worked examples',
  'The data readiness check, and why you don’t need a warehouse',
  'Searching everything your business knows · RAG, demystified',
  'What AI actually costs in the UK, with real price bands',
  'Maximising your ROI: calculating the return and the levers that move it',
  'Build it, buy it, or use no-code: the decision tree',
  'Everyday tools · agents & harnesses · orchestration',
  'Workflow or agent? Choosing the right system, and why',
  'Prove it in six weeks · the questions that keep providers honest',
];
---

<BaseLayout
  title="Free AI Adoption Playbook for Small Businesses | North Point Digital"
  description="Download the free AI Adoption Playbook: plan, validate, and scale AI in your business with practical guidance from engineers, whatever systems you run today."
  canonical="https://northpointdigital.com/ai-adoption-playbook"
  breadcrumbs={[{ name: 'Home', url: siteUrl }, { name: 'AI Adoption Playbook', url: `${siteUrl}/ai-adoption-playbook` }]}
  jsonLd={{ "@context": "https://schema.org", "@type": "TechArticle", headline: "AI Adoption Playbook for Small Businesses", description: "A practical guide to planning, validating, and scaling AI in a small business, created by North Point Digital.", author: { "@type": "Organization", name: "North Point Digital" }, publisher: { "@type": "Organization", name: "North Point Digital", logo: { "@type": "ImageObject", url: `${siteUrl}/north-point-logo.webp` } }, mainEntityOfPage: { "@type": "WebPage", "@id": `${siteUrl}/ai-adoption-playbook` } }}
>
  <section class="relative overflow-hidden bg-white pt-16">
    <div class="hero-tint" aria-hidden="true"></div>
    <div class="hero-dots" aria-hidden="true"></div>
    <div class="container-site relative py-20 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-6">Free download</p>
        <h1 class="text-h1">The AI Adoption Playbook</h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 md:text-xl">
          A practical guide to planning, validating and scaling AI in your
          organisation, written for the people who have to make it work rather
          than just announce it.
        </p>
      </div>

      <div class="mx-auto mt-12 max-w-5xl">
        <div class="grid grid-cols-3 gap-4 md:gap-6" data-reveal>
          <img src="/images/playbook/preview-data-layer.jpg" alt="Sample page: consolidate or connect your data" width="909" height="1285" loading="lazy" class="w-full rounded-lg border border-slate-200 shadow-sm" />
          <img src="/images/playbook/preview-rag.jpg" alt="Sample page: RAG, demystified" width="909" height="1285" loading="lazy" class="w-full rounded-lg border border-slate-200 shadow-sm" />
          <img src="/images/playbook/preview-framework.jpg" alt="Sample page: the decision framework" width="909" height="1285" loading="lazy" class="w-full rounded-lg border border-slate-200 shadow-sm" />
        </div>
        <p class="mt-4 text-center text-sm text-slate-500">
          Three of the nineteen pages: connecting your data, RAG demystified, and the
          decision framework. What you see is what you get.
        </p>
      </div>

      <div class="mx-auto mt-14 grid max-w-5xl grid-cols-1 items-start gap-8 lg:grid-cols-2">
        <div class="card lg:p-10">
          <h2 class="text-xl font-semibold text-slate-900">What's inside</h2>
          <p class="mt-1 text-sm text-slate-500">19 pages · about a twenty-five-minute read</p>
          <ul class="mt-5 space-y-2.5">
            {contents.map((item) => (
              <li class="flex items-start gap-2.5 text-[0.95rem] leading-relaxed text-slate-700">
                <svg class="mt-1 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="card lg:p-10">
          <h2 class="text-center text-xl font-semibold text-slate-900">Get the playbook</h2>
          <p class="mt-2 text-center text-slate-600">
            Fill in the form and we'll send it straight over. You'll also get a
            handful of short follow-up notes from us. Unsubscribe any time, no
            hard feelings.
          </p>
          <div class="mt-6 playbook-form">
            <div id="mlb2-42471936" class="ml-form-embedContainer ml-subscribe-form ml-subscribe-form-42471936">
              <div class="ml-form-align-center">
                <div class="ml-form-embedWrapper embedForm">
                  <div class="ml-form-embedBody ml-form-embedBodyDefault row-form">
                    <form class="ml-block-form" action="https://assets.mailerlite.com/jsonp/2423627/forms/189963976859190614/subscribe" data-code="" method="post" target="_blank">
                      <div class="ml-form-formContent">
                        <div class="ml-form-fieldRow ml-last-item">
                          <div class="ml-field-group ml-field-email ml-validate-email ml-validate-required">
                            <input aria-label="email" aria-required="true" type="email" class="form-control" data-inputmask="" name="fields[email]" placeholder="Your email address" autocomplete="email" />
                          </div>
                        </div>
                      </div>

                      <div class="ml-form-checkboxRow ml-validate-required">
                        <label class="checkbox">
                          <input type="checkbox" />
                          <div class="label-description">
                            <p>Opt in to receive news and updates.</p>
                          </div>
                        </label>
                      </div>

                      <div class="ml-form-recaptcha ml-validate-required">
                        <div class="g-recaptcha" data-sitekey="6Lf1KHQUAAAAAFNKEX1hdSWCS3mRMv4FlFaNslaD"></div>
                      </div>

                      <input type="hidden" name="ml-submit" value="1" />

                      <div class="ml-form-embedSubmit">
                        <button type="submit" class="primary">Download the playbook</button>
                        <button disabled="disabled" style="display: none;" type="button" class="loading">
                          <div class="ml-form-embedSubmitLoad"></div>
                          <span class="sr-only">Loading...</span>
                        </button>
                      </div>

                      <input type="hidden" name="anticsrf" value="true" />
                    </form>
                  </div>

                  <div class="ml-form-successBody row-success" style="display: none">
                    <div class="ml-form-successContent">
                      <h4>Thank you!</h4>
                      <p>Check your inbox. The playbook is on its way.</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    function ml_webform_success_42471936() {
      // Track the download before touching the DOM, so a UI error can't
      // swallow the conversion event.
      if (typeof gtag === 'function') {
        gtag('event', 'playbook_download', { event_category: 'conversion', event_label: 'AI Adoption Playbook' });
        gtag('event', 'generate_lead', { event_category: 'conversion', event_label: 'Playbook Download', currency: 'GBP', value: 1 });
      }
      var $ = ml_jQuery || jQuery;
      $('.ml-subscribe-form-42471936 .row-success').show();
      $('.ml-subscribe-form-42471936 .row-form').hide();
    }
  </script>
  <script is:inline src="https://groot.mailerlite.com/js/w/webforms.min.js?v83147fa8ce2d95cb73ece7f28b469519" type="text/javascript"></script>
  <script is:inline>
    fetch('https://assets.mailerlite.com/jsonp/2423627/forms/189963976859190614/takel');
  </script>
  <script is:inline src="https://www.google.com/recaptcha/api.js"></script>

  <style is:global>
    .playbook-form,
    .playbook-form * {
      font-family: 'Geist Variable', Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      box-sizing: border-box;
    }

    .playbook-form .ml-form-embedContainer,
    .playbook-form .ml-form-embedWrapper {
      width: 100%;
      max-width: 100%;
      background: transparent;
      border: 0;
      box-shadow: none;
      display: block;
    }

    .playbook-form .ml-form-embedBody {
      padding: 0;
    }

    .playbook-form .ml-form-fieldRow {
      margin: 0 0 0.875rem 0;
    }

    .playbook-form input[type='email'],
    .playbook-form input[type='text'],
    .playbook-form .form-control {
      width: 100%;
      border: 1px solid #e2e8f0;
      border-radius: 0.75rem;
      padding: 0.75rem 1rem;
      font-size: 0.95rem;
      line-height: 1.5;
      color: #0f172a;
      background: #ffffff;
      transition: border-color 200ms ease, box-shadow 200ms ease;
    }

    .playbook-form input[type='email']:focus,
    .playbook-form input[type='text']:focus,
    .playbook-form .form-control:focus {
      border-color: #2563eb;
      outline: none;
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
    }

    .playbook-form input::placeholder {
      color: #94a3b8;
    }

    .playbook-form .ml-form-checkboxRow {
      margin: 0 0 1rem 0;
    }

    .playbook-form .ml-form-checkboxRow label.checkbox {
      display: flex;
      align-items: flex-start;
      gap: 0.5rem;
      margin: 0;
      cursor: pointer;
    }

    .playbook-form .ml-form-checkboxRow input[type='checkbox'] {
      margin-top: 0.2rem;
      width: 1rem;
      height: 1rem;
      accent-color: #2563eb;
      flex-shrink: 0;
    }

    .playbook-form .ml-form-checkboxRow .label-description,
    .playbook-form .ml-form-checkboxRow .label-description p {
      color: #475569;
      font-size: 0.85rem;
      line-height: 1.5;
      margin: 0;
    }

    .playbook-form .ml-form-recaptcha {
      margin: 0 0 1rem 0;
    }

    .playbook-form .ml-form-embedSubmit {
      position: relative;
    }

    .playbook-form .ml-form-embedSubmit button,
    .playbook-form .ml-form-embedSubmit button.primary {
      width: 100%;
      background: #2563eb;
      border: 0;
      border-radius: 0.75rem;
      color: #ffffff;
      font-weight: 600;
      font-size: 0.95rem;
      line-height: 1.4;
      padding: 0.75rem 1.25rem;
      cursor: pointer;
      transition: background-color 200ms ease;
    }

    .playbook-form .ml-form-embedSubmit button:hover,
    .playbook-form .ml-form-embedSubmit button.primary:hover {
      background: #1d4ed8;
    }

    .playbook-form .ml-form-embedSubmit button.loading {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
    }

    .playbook-form .ml-form-successContent {
      text-align: center;
    }

    .playbook-form .ml-form-successContent h4 {
      color: #0f172a;
      font-size: 1.25rem;
      font-weight: 600;
      margin: 0 0 0.5rem 0;
    }

    .playbook-form .ml-form-successContent p {
      color: #475569;
      margin: 0;
    }

    .playbook-form .ml-error input,
    .playbook-form .ml-error .form-control {
      border-color: #ef4444 !important;
    }

    .playbook-form .ml-error .label-description,
    .playbook-form .ml-error .label-description p {
      color: #ef4444 !important;
    }

    .playbook-form .ml-form-embedSubmitLoad {
      display: inline-block;
      width: 20px;
      height: 20px;
    }

    .playbook-form .ml-form-embedSubmitLoad:after {
      content: ' ';
      display: block;
      width: 11px;
      height: 11px;
      margin: 1px;
      border-radius: 50%;
      border: 4px solid #fff;
      border-color: #ffffff #ffffff #ffffff transparent;
      animation: ml-form-embedSubmitLoad 1.2s linear infinite;
    }

    @keyframes ml-form-embedSubmitLoad {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    @media only screen and (max-width: 480px) {
      .playbook-form .g-recaptcha {
        transform: scale(0.9);
        transform-origin: 0 0;
      }
    }
  </style>
</BaseLayout>
