---
import BaseLayout from '../layouts/BaseLayout.astro';
import HubSpotForm from '../components/HubSpotForm';
import PlaybookLeadCaptureForm from '../components/PlaybookLeadCaptureForm';
import { HUBSPOT_CONFIG } from '../config/hubspot';

const isHubSpotConfigured = HUBSPOT_CONFIG.portalId !== 'YOUR_PORTAL_ID' && !HUBSPOT_CONFIG.forms.aiPlaybook.includes('YOUR_');
const siteUrl = 'https://northpointdigital.com';

const benefits = [
  {
    title: 'A strategy you can defend',
    description: 'A step-by-step framework for picking AI use cases that survive contact with the budget meeting.',
  },
  {
    title: 'An implementation route',
    description: 'The path from idea to production, including the bits most write-ups skip — data readiness and what it costs to run.',
  },
  {
    title: 'Use cases that fit',
    description: 'Worked examples sized for small and mid-sized businesses, not enterprise science projects.',
  },
];
---

<BaseLayout
  title="Free AI Adoption Playbook for Small Businesses | North Point Digital"
  description="Download the free AI Adoption Playbook: plan, validate, and scale AI in your business with practical guidance from engineers — whatever systems you run today."
  canonical="https://northpointdigital.com/ai-adoption-playbook"
  breadcrumbs={[{ name: 'Home', url: siteUrl }, { name: 'AI Adoption Playbook', url: `${siteUrl}/ai-adoption-playbook` }]}
  jsonLd={{ "@context": "https://schema.org", "@type": "TechArticle", headline: "AI Adoption Playbook for Small Businesses", description: "A practical guide to planning, validating, and scaling AI in a small business, created by North Point Digital.", author: { "@type": "Organization", name: "North Point Digital" }, publisher: { "@type": "Organization", name: "North Point Digital", logo: { "@type": "ImageObject", url: `${siteUrl}/north-point-logo.webp` } }, mainEntityOfPage: { "@type": "WebPage", "@id": `${siteUrl}/ai-adoption-playbook` } }}
>
  <section class="relative overflow-hidden bg-white pt-16">
    <div class="pointer-events-none absolute inset-x-0 top-0 h-[420px] bg-[radial-gradient(ellipse_at_top,#eff6ff_0%,transparent_65%)]" aria-hidden="true"></div>
    <div class="container-site relative py-20 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-6">Free download</p>
        <h1 class="text-h1">The AI Adoption Playbook</h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 md:text-xl">
          A practical guide to planning, validating and scaling AI in your
          organisation — written for people who have to make it work, not just
          announce it.
        </p>
      </div>

      <div class="mx-auto mt-14 grid max-w-5xl grid-cols-1 items-start gap-8 lg:grid-cols-2">
        <div class="space-y-4">
          {benefits.map((b) => (
            <div class="card">
              <h2 class="text-lg font-semibold text-slate-900">{b.title}</h2>
              <p class="mt-2 leading-relaxed text-slate-600">{b.description}</p>
            </div>
          ))}
        </div>

        <div class="card lg:p-10">
          <h2 class="text-center text-xl font-semibold text-slate-900">Get the playbook</h2>
          <p class="mt-2 text-center text-slate-600">
            Fill in the form and we'll send it straight over.
          </p>
          <div class="mt-6">
            {isHubSpotConfigured ? (
              <HubSpotForm client:idle formType="aiPlaybook" region={HUBSPOT_CONFIG.region} />
            ) : (
              <PlaybookLeadCaptureForm client:idle />
            )}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
