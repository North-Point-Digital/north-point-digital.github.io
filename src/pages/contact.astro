---
import BaseLayout from '../layouts/BaseLayout.astro';
import HubSpotForm from '../components/HubSpotForm';
import SimpleContactForm from '../components/SimpleContactForm';
import { HUBSPOT_CONFIG } from '../config/hubspot';

const isHubSpotConfigured = HUBSPOT_CONFIG.portalId !== 'YOUR_PORTAL_ID' && !HUBSPOT_CONFIG.forms.contact.includes('YOUR_');
const siteUrl = 'https://northpointdigital.com';
---

<BaseLayout
  title="Contact North Point Digital | AWS Cloud Consultancy"
  description="Get in touch with North Point Digital to discuss AWS cost optimisation, security, and cloud or AI projects."
  canonical="https://northpointdigital.com/contact"
  breadcrumbs={[{ name: 'Home', url: siteUrl }, { name: 'Contact', url: `${siteUrl}/contact` }]}
  jsonLd={{ "@context": "https://schema.org", "@type": "ContactPage", name: "Contact North Point Digital", url: `${siteUrl}/contact`, mainEntity: { "@type": "Organization", name: "North Point Digital", email: "contact@northpointdigital.com", url: `${siteUrl}/` } }}
>
  <section class="relative overflow-hidden bg-white pt-16">
    <div class="hero-tint" aria-hidden="true"></div>
    <div class="hero-dots" aria-hidden="true"></div>
    <div class="container-site relative py-20 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-6">Contact</p>
        <h1 class="text-h1">Get in touch</h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 md:text-xl">
          Tell us what you're working on — AI, costs, security, a migration — and
          we'll come back with a straight answer.
        </p>
      </div>

      <div class="mx-auto mt-14 grid max-w-5xl grid-cols-1 items-start gap-8 lg:grid-cols-[2fr_3fr]">
        <div class="space-y-4">
          <div class="card">
            <h2 class="text-lg font-semibold text-slate-900">Email</h2>
            <p class="mt-2 text-slate-600">For anything — enquiries, questions, or just to introduce yourself.</p>
            <a href="mailto:contact@northpointdigital.com" class="mt-3 inline-block font-medium text-accent no-underline hover:underline">
              contact@northpointdigital.com
            </a>
          </div>
          <div class="card">
            <h2 class="text-lg font-semibold text-slate-900">Prefer to talk?</h2>
            <p class="mt-2 text-slate-600">Book a free 30-minute call directly into the calendar.</p>
            <a
              href="https://calendly.com/david-northpointdigital/north-point-digital-initial-call"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-3 inline-block font-medium text-accent no-underline hover:underline"
              data-track-cta="Contact Book a Call"
            >
              Book a free call →
            </a>
          </div>
          <div class="card">
            <h2 class="text-lg font-semibold text-slate-900">Where we are</h2>
            <p class="mt-2 text-slate-600">A remote-first consultancy based in the UK, working with clients wherever AWS is.</p>
          </div>
        </div>

        <div class="card lg:p-10">
          <h2 class="text-xl font-semibold text-slate-900">Send us a message</h2>
          <p class="mt-2 text-slate-600">We aim to reply within one working day.</p>
          <div class="mt-6">
            {isHubSpotConfigured ? (
              <HubSpotForm client:idle formType="contact" region={HUBSPOT_CONFIG.region} />
            ) : (
              <SimpleContactForm client:idle />
            )}
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
