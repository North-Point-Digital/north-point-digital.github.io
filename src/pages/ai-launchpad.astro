---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSection from '../components/FAQSection.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import { buildFaqJsonLd } from '../data/faqs';

const CTA_LINK = 'https://calendly.com/david-northpointdigital/30min';
const siteUrl = 'https://northpointdigital.com';

const deliverables = [
  {
    title: 'A working prototype',
    description:
      'Built with your data, on secure cloud infrastructure we set up and run. Your systems stay where they are. Software you can put in front of users, not a slide deck.',
  },
  {
    title: 'Production costings',
    description:
      'An executive summary with running-cost projections and ROI analysis, so the decision to proceed (or not) is a financial one, not a hopeful one.',
  },
  {
    title: 'A route to live',
    description:
      'A step-by-step roadmap for taking the prototype to a production deployment — architecture, security, and the order to do things in.',
  },
];

const phases = [
  {
    label: 'Week 1',
    title: 'Scope',
    description:
      'We pick the use case together, look at your data, and agree exactly what the prototype has to prove.',
  },
  {
    label: 'Weeks 2–5',
    title: 'Build',
    description:
      'We build the proof of concept on AWS with your data. Weekly demos — you watch it take shape and steer as we go.',
  },
  {
    label: 'Week 6',
    title: 'Prove',
    description:
      'Working prototype, production costings and roadmap, handed over with a session for your team.',
  },
];
---

<BaseLayout
  title="AI Launchpad: Validate Your AI Strategy in 6 Weeks | North Point Digital"
  description="Fixed-fee AWS AI proof of concept that validates your AI strategy in six weeks with a working prototype, cost analysis, and production roadmap."
  canonical="https://northpointdigital.com/ai-launchpad"
  breadcrumbs={[{ name: 'Home', url: siteUrl }, { name: 'Services', url: `${siteUrl}/#services` }, { name: 'AI Launchpad', url: `${siteUrl}/ai-launchpad` }]}
  jsonLd={[
    { "@context": "https://schema.org", "@type": "Service", name: "AI Launchpad", description: "Fixed-fee AI proof of concept that validates your AI strategy in six weeks with a working prototype, cost analysis, and production roadmap.", url: `${siteUrl}/ai-launchpad`, provider: { "@type": "Organization", name: "North Point Digital", url: `${siteUrl}/` }, areaServed: { "@type": "Country", name: "United Kingdom" }, serviceType: "AI Proof of Concept and Strategy Validation", offers: { "@type": "AggregateOffer", priceCurrency: "GBP", lowPrice: "15000", highPrice: "25000", description: "Fixed fee agreed before the engagement starts; position in the range depends on data readiness." } },
    buildFaqJsonLd(),
  ]}
>
  <section class="relative overflow-hidden bg-white pt-16">
    <div class="hero-tint" aria-hidden="true"></div>
    <div class="hero-dots" aria-hidden="true"></div>
    <div class="container-site relative flex flex-col items-center py-20 text-center md:py-28">
      <p class="eyebrow mb-6">AI Launchpad · Fixed fee</p>
      <h1 class="max-w-4xl text-h1">Validate your AI strategy in six weeks</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 md:text-xl">
        A fixed-fee proof of concept built with your data — wherever it lives today.
        You finish with working software, honest running costs and a route to live,
        or a clear, documented reason not to proceed. Both are worth knowing.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href={CTA_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary" data-track-cta="Launchpad Book a Call">
          Book a free call
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
        <a href="/ai-adoption-playbook" class="btn-secondary" data-track-cta="Launchpad Download Playbook">
          Get the AI Adoption Playbook
        </a>
      </div>

      {/* The six weeks, drawn to scale */}
      <svg class="mt-16 w-full max-w-2xl" viewBox="0 0 640 120" fill="none" aria-hidden="true">
        <rect x="2" y="34" width="104" height="36" rx="8" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.5" />
        <rect x="110" y="34" width="422" height="36" rx="8" fill="#eff6ff" stroke="#2563eb" stroke-width="1.5" />
        <rect x="536" y="34" width="102" height="36" rx="8" fill="#f0fdf4" stroke="#059669" stroke-width="1.5" />
        <text x="54" y="57" text-anchor="middle" fill="#475569" font-size="13" font-weight="600" font-family="ui-monospace, monospace">scope</text>
        <text x="321" y="57" text-anchor="middle" fill="#2563eb" font-size="13" font-weight="600" font-family="ui-monospace, monospace">build · weekly demos</text>
        <text x="587" y="57" text-anchor="middle" fill="#059669" font-size="13" font-weight="600" font-family="ui-monospace, monospace">prove</text>
        <text x="54" y="92" text-anchor="middle" fill="#94a3b8" font-size="11" font-family="ui-monospace, monospace">week 1</text>
        <text x="321" y="92" text-anchor="middle" fill="#94a3b8" font-size="11" font-family="ui-monospace, monospace">weeks 2–5</text>
        <text x="587" y="92" text-anchor="middle" fill="#94a3b8" font-size="11" font-family="ui-monospace, monospace">week 6</text>
        <text x="321" y="16" text-anchor="middle" fill="#64748b" font-size="12" font-family="ui-monospace, monospace">one fixed fee, agreed before week 1</text>
      </svg>
    </div>
  </section>

  <section class="section border-t border-slate-200 bg-slate-50">
    <div class="container-site">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-4">What you get</p>
        <h2 class="text-h2">Three deliverables, no slideware</h2>
        <p class="mt-4 text-lg text-slate-600">
          We don't build generic chatbots. The Launchpad exists to prove — or
          disprove — a specific use case with your own data.
        </p>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-3" data-reveal>
        {deliverables.map((d) => (
          <div class="card">
            <h3 class="text-lg font-semibold text-slate-900">{d.title}</h3>
            <p class="mt-3 leading-relaxed text-slate-600">{d.description}</p>
          </div>
        ))}
      </div>
      <p class="mx-auto mt-10 max-w-2xl text-center text-slate-600">
        On-prem, Microsoft, Google, or nothing fancier than spreadsheets — it doesn't
        matter. We connect to your data where it is, and you never touch the
        infrastructure. <a href="/#examples" class="font-medium text-accent no-underline hover:underline">See working examples →</a>
      </p>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-site">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-4">How it runs</p>
        <h2 class="text-h2">Six weeks, start to finish</h2>
        <p class="mt-4 text-lg text-slate-600">
          The price is fixed before we start, and you see progress every week.
        </p>
      </div>
      <ol class="mx-auto mt-14 grid max-w-4xl grid-cols-1 gap-6 md:grid-cols-3" data-reveal>
        {phases.map((phase) => (
          <li class="card h-full">
            <span class="font-mono text-sm font-medium text-accent">{phase.label}</span>
            <h3 class="mt-3 text-lg font-semibold text-slate-900">{phase.title}</h3>
            <p class="mt-2 text-[0.95rem] leading-relaxed text-slate-600">{phase.description}</p>
          </li>
        ))}
      </ol>
      <p class="mt-8 text-center text-sm text-slate-500">
        Indicative shape — the exact split depends on your use case and data.
      </p>
    </div>
  </section>

  <section class="section border-t border-slate-200 bg-slate-50">
    <div class="container-site">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-4">Pricing</p>
        <h2 class="text-h2">What it costs</h2>
      </div>

      <div class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-6 lg:grid-cols-2">
        <div class="card lg:p-10">
          <p class="font-mono text-3xl font-semibold tracking-tight text-slate-900">£15,000–£25,000</p>
          <p class="mt-1 text-sm font-medium text-slate-500">fixed fee, agreed in writing before we start</p>
          <p class="mt-5 leading-relaxed text-slate-600">
            Where you land in that range depends mostly on data readiness. If what
            the AI needs lives in one system and exports cleanly, you're at the
            bottom of it. If it's scattered across five tools and a shared drive,
            the scoping week earns its keep — and the quote reflects the extra work
            honestly, before you commit.
          </p>
          <p class="mt-4 leading-relaxed text-slate-600">
            The fee covers everything above: the working prototype, production
            costings, the roadmap, and handover. Once agreed, it doesn't move.
          </p>
        </div>

        <div class="card border-accent/30 bg-gradient-to-b from-accent-tint/60 to-white lg:p-10">
          <p class="eyebrow mb-3">Founding clients</p>
          <h3 class="text-xl font-semibold text-slate-900">Roughly half the usual fee</h3>
          <p class="mt-4 leading-relaxed text-slate-600">
            We're building our public case-study library and we're open about it:
            our first three Launchpad clients get the full engagement at roughly
            half the usual fee, in exchange for a named case study and a reference
            call. Same scope, same team, same deliverables.
          </p>
          <p class="mt-4 leading-relaxed text-slate-600">
            When the three slots are gone, they're gone.
          </p>
          <a href={CTA_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary mt-6" data-track-cta="Launchpad Founding Slot">
            Ask about a founding slot
          </a>
        </div>
      </div>
    </div>
  </section>

  <FAQSection framed />

  <ClosingCTA
    title="Got a use case in mind?"
    subtitle="Bring it to a free 30-minute call. We'll tell you honestly whether a Launchpad would prove it — and what it would cost."
    calendly={CTA_LINK}
  />
</BaseLayout>
