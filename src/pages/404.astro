---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | North Point Digital" description="The page you're looking for doesn't exist." noIndex={true}>
  <section class="flex min-h-[70vh] items-center justify-center bg-white pt-16">
    <div class="container-site py-20 text-center">
      <p class="font-mono text-[clamp(4rem,10vw,7rem)] font-semibold leading-none tracking-tight text-slate-200">404</p>
      <h1 class="mt-4 text-2xl font-semibold text-slate-900">Page not found</h1>
      <p class="mx-auto mt-3 max-w-md text-lg text-slate-600">
        The page you're looking for doesn't exist or has moved.
      </p>
      <a href="/" class="btn-primary mt-8">Back to the homepage</a>
    </div>
  </section>
</BaseLayout>
