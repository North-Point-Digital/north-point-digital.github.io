---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank You for Booking | North Point Digital"
  description="Your consultation with North Point Digital is confirmed. Check your email for calendar details and joining instructions."
  canonical="https://northpointdigital.com/thank-you"
  jsonLd={{ "@context": "https://schema.org", "@type": "Reservation", reservationStatus: "https://schema.org/ReservationConfirmed", provider: { "@type": "Organization", name: "North Point Digital" } }}
>
  <section class="flex min-h-screen items-center justify-center bg-slate-50 pt-16">
    <div class="container-site max-w-3xl py-16">
      <div class="card p-10 text-center md:p-14">
        <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-accent-tint">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-10 w-10 text-accent" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
        </div>
        <h1 class="mt-8 text-[clamp(1.875rem,3.5vw,2.5rem)] font-semibold tracking-tight text-slate-900">Thanks, you're booked in</h1>
        <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-slate-600" id="thank-you-subtitle">
          We've received your booking and we're looking forward to the call. A
          confirmation email with the details is on its way.
        </p>

        <div id="meeting-details" class="my-8 hidden rounded-2xl border border-slate-200 bg-slate-50 p-8 text-left"></div>

        <div class="my-8 rounded-2xl border border-slate-200 bg-slate-50 p-8 text-left">
          <h2 class="text-lg font-semibold text-slate-900">What happens next</h2>
          <ul class="mt-4 list-disc space-y-2 pl-6 leading-relaxed text-slate-600">
            <li>You'll get a calendar confirmation email with the meeting details</li>
            <li>We'll send a short pre-call questionnaire so we arrive prepared</li>
            <li>We'll review your requirements before the call</li>
            <li>On the call, we'll talk through where AI and cost savings fit your estate</li>
          </ul>
        </div>

        <div class="my-8 rounded-2xl border border-accent/30 bg-accent-tint p-8 text-left">
          <h2 class="text-lg font-semibold text-slate-900">While you wait</h2>
          <p class="mt-3 leading-relaxed text-slate-600">
            The AI Adoption Playbook is worth twenty minutes before our call. It
            covers how to pick a use case worth proving, and the questions we'll
            probably ask you.
          </p>
          <a href="/ai-adoption-playbook" class="btn-primary mt-5" data-track-cta="Thank You Playbook">
            Get the playbook
          </a>
        </div>

        <div class="my-8 rounded-2xl border border-slate-200 bg-slate-50 p-8 text-left">
          <h2 class="text-lg font-semibold text-slate-900">Need to make changes?</h2>
          <ul class="mt-4 list-disc space-y-2 pl-6 leading-relaxed text-slate-600">
            <li>Check your email for the calendar confirmation</li>
            <li>Use the reschedule link in the email to change the time</li>
            <li>Or email <a href="mailto:contact@northpointdigital.com" class="font-medium text-accent no-underline hover:underline">contact@northpointdigital.com</a> with any questions</li>
          </ul>
        </div>

        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href="/" class="btn-primary">Return to the homepage</a>
          <button onclick="history.back()" class="btn-secondary">← Go back</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  if (typeof window.gtag === 'function') {
    window.gtag('event', 'conversion', { 'send_to': 'AW-17883979518/uoRQCMuWk-gbEP69389C' });
  }

  (function () {
    var params = new URLSearchParams(window.location.search);
    var startTime = params.get('event_start_time');
    if (!startTime) return;

    var name = params.get('invitee_name');
    var email = params.get('invitee_email');
    var eventType = params.get('event_type_name') || 'Free Consultation';
    var start = new Date(startTime);
    var endParam = params.get('event_end_time');

    var subtitle = document.getElementById('thank-you-subtitle');
    if (subtitle && name) {
      subtitle.textContent = 'Hi ' + name + ", your booking is confirmed. We're looking forward to speaking with you.";
    }

    var details = document.getElementById('meeting-details');
    if (details) {
      details.classList.remove('hidden');
      var html = '<h2 class="text-lg font-semibold text-slate-900">Meeting confirmation</h2>';
      html += '<div class="mt-4"><strong class="block text-xs uppercase tracking-wider text-slate-500">Date &amp; time</strong><span class="mt-1 block font-semibold text-slate-900">' + start.toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) + '</span><span class="mt-0.5 block text-slate-600">' + start.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', timeZoneName: 'short' }) + (endParam ? ' – ' + new Date(endParam).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', timeZoneName: 'short' }) : '') + '</span></div>';
      if (eventType) html += '<div class="mt-4"><strong class="block text-xs uppercase tracking-wider text-slate-500">Meeting type</strong><span class="mt-1 block font-semibold text-slate-900">' + eventType + '</span></div>';
      if (name) html += '<div class="mt-4"><strong class="block text-xs uppercase tracking-wider text-slate-500">Attendee</strong><span class="mt-1 block font-semibold text-slate-900">' + name + '</span>' + (email ? '<span class="mt-0.5 block text-sm text-slate-600">' + email + '</span>' : '') + '</div>';
      details.innerHTML = html;
    }
  })();
</script>
