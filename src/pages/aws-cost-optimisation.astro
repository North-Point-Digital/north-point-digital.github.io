---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQSection from '../components/FAQSection.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import { buildFaqJsonLd } from '../data/faqs';

const CTA_LINK = 'https://calendly.com/david-northpointdigital/30min';
const siteUrl = 'https://northpointdigital.com';

const stats = [
  { number: '20+', label: 'reviews completed' },
  { number: '30%', label: 'average savings found' },
  { number: '£0', label: 'upfront cost' },
];

const costLevers = [
  'Rightsizing over-provisioned EC2, RDS and EBS using AWS Compute Optimizer and utilisation data',
  'Savings Plans and Reserved Instances modelled against your real usage, not a sales target',
  'Idle and orphaned resources: unattached EBS volumes, old snapshots, unused Elastic IPs and load balancers',
  'S3 storage-class tiering and lifecycle policies to move cold data off Standard',
  'Graviton and managed/serverless moves where they cut cost without a rewrite',
  'Cost Explorer analysis, a consistent tagging model, and budget alerts so spend stays visible after we leave',
];

const securityLevers = [
  'IAM review: over-permissive roles, unused access keys, missing MFA and root-account exposure',
  'Public exposure checks across S3, security groups and network ACLs',
  'Encryption at rest and in transit, and AWS KMS key hygiene',
  'Logging and guardrails: CloudTrail, AWS Config, GuardDuty and Trusted Advisor findings',
  'Account structure and isolation between production and non-production',
];

const requirements = [
  'Read-only access to your AWS account (or a billing and architecture export if you prefer)',
  'A 30-minute kickoff call to understand what each workload does',
  'A point of contact for any change we want to apply during the engagement',
];

const relatedPosts = [
  { title: 'Reduce your AWS bill without rewriting everything', href: '/blog/reduce-aws-bill-without-rewriting-everything' },
  { title: 'Building on Bedrock: why your business needs an AWS landing zone', href: '/blog/landing-zones-for-growing-aws-teams' },
];

const timelineSteps = [
  {
    week: 'Week 1',
    title: 'Discovery & analysis',
    items: [
      'Full account audit and cost analysis',
      'Security vulnerability assessment',
      'Architecture review',
      'Initial findings report with quick wins',
    ],
  },
  {
    week: 'Week 2',
    title: 'Implementation & optimisation',
    items: [
      'Remediation of critical security issues',
      'Cost optimisation implementation',
      'Budget alerts and tagging setup',
      'Performance tuning',
    ],
  },
  {
    week: 'Delivery',
    title: 'Final report & roadmap',
    items: [
      'Full Well-Architected report',
      'Long-term optimisation roadmap',
      'Knowledge transfer session',
      '30 days of support included',
    ],
  },
];

const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How the Security & Cost Optimisation Blueprint works",
  description: "A two-week AWS Well-Architected review: discover and analyse the estate, implement cost and security fixes during the engagement, then hand over a full report and roadmap.",
  totalTime: "P2W",
  step: timelineSteps.map((step) => ({
    "@type": "HowToStep",
    name: `${step.week} — ${step.title}`,
    text: step.items.join('. '),
  })),
};
---

<BaseLayout
  title="Security & Cost Optimisation Blueprint | North Point Digital"
  description="Comprehensive AWS Well-Architected review focused on security and cost optimisation, targeting 25%+ savings while strengthening your cloud posture."
  canonical="https://northpointdigital.com/aws-cost-optimisation"
  breadcrumbs={[{ name: 'Home', url: siteUrl }, { name: 'Services', url: `${siteUrl}/#services` }, { name: 'Security & Cost Optimisation Blueprint', url: `${siteUrl}/aws-cost-optimisation` }]}
  jsonLd={[
    { "@context": "https://schema.org", "@type": "Service", name: "Security & Cost Optimisation Blueprint", description: "Comprehensive AWS Well-Architected review focused on security and cost optimisation, targeting 25%+ savings while strengthening your cloud posture.", url: `${siteUrl}/aws-cost-optimisation`, provider: { "@type": "Organization", name: "North Point Digital", url: `${siteUrl}/` }, areaServed: { "@type": "Country", name: "United Kingdom" }, serviceType: "AWS Security and Cost Optimisation Consulting" },
    howToJsonLd,
    buildFaqJsonLd(),
  ]}
>
  <section class="relative overflow-hidden bg-white pt-16">
    <div class="hero-tint" aria-hidden="true"></div>
    <div class="hero-dots" aria-hidden="true"></div>
    <div class="container-site relative flex flex-col items-center py-20 text-center md:py-28">
      <p class="eyebrow mb-6">Well-Architected review · No upfront cost</p>
      <h1 class="max-w-4xl text-h1">Security &amp; Cost Optimisation Blueprint</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 md:text-xl">
        A two-week AWS Well-Architected review of your estate, focused on the two pillars that
        pay for themselves: cost and security. We target 25%+ savings and fix critical
        issues while we're in there, not after the report lands.
      </p>
      <p class="mt-5 inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-emerald-50 px-4 py-2 text-sm font-medium text-emerald-800">
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 12l2 2 4-4M12 3l7 4v5a8 8 0 0 1-7 8 8 8 0 0 1-7-8V7l7-4z" />
        </svg>
        Our guarantee: if we don't find at least 25% in potential savings, there's no fee.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
        <a href={CTA_LINK} target="_blank" rel="noopener noreferrer" class="btn-primary" data-track-cta="Blueprint Book a Call">
          Book a free call
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
        <a href="/contact" class="btn-secondary" data-track-cta="Blueprint Contact">
          Prefer email? Tell us your setup
        </a>
      </div>

      <dl class="mt-14 grid w-full max-w-2xl grid-cols-1 gap-4 sm:grid-cols-3">
        {stats.map((stat) => (
          <div class="card !p-6 text-center">
            <dt class="order-2 mt-1 text-sm text-slate-600">{stat.label}</dt>
            <dd class="order-1 font-mono text-3xl font-semibold tracking-tight text-slate-900">{stat.number}</dd>
          </div>
        ))}
      </dl>

      {/* Your bill, before and after */}
      <svg class="mt-14 w-full max-w-md" viewBox="0 0 440 190" fill="none" aria-hidden="true">
        <g font-family="ui-monospace, monospace">
          <rect x="60" y="30" width="100" height="120" rx="8" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.5" />
          <rect x="60" y="30" width="100" height="42" rx="8" fill="#fef2f2" stroke="#fca5a5" stroke-width="1.5" />
          <text x="110" y="56" text-anchor="middle" fill="#dc2626" font-size="12" font-weight="600">waste</text>
          <text x="110" y="115" text-anchor="middle" fill="#475569" font-size="12">your bill</text>
          <text x="110" y="172" text-anchor="middle" fill="#94a3b8" font-size="11">before</text>

          <path d="M185 90h60" stroke="#94a3b8" stroke-width="1.5" stroke-dasharray="5 5" />
          <path d="M239 84l8 6-8 6" fill="none" stroke="#94a3b8" stroke-width="1.5" />
          <text x="215" y="78" text-anchor="middle" fill="#64748b" font-size="11">2 weeks</text>

          <rect x="280" y="72" width="100" height="78" rx="8" fill="#f8fafc" stroke="#cbd5e1" stroke-width="1.5" />
          <text x="330" y="115" text-anchor="middle" fill="#475569" font-size="12">your bill</text>
          <text x="330" y="172" text-anchor="middle" fill="#94a3b8" font-size="11">after</text>
          <rect x="280" y="30" width="100" height="34" rx="8" fill="#f0fdf4" stroke="#059669" stroke-width="1.5" />
          <text x="330" y="51" text-anchor="middle" fill="#059669" font-size="12" font-weight="600">25%+ back</text>
        </g>
      </svg>
    </div>
  </section>

  <section class="section border-t border-slate-200 bg-slate-50">
    <div class="container-site max-w-4xl">
      <div class="text-center">
        <p class="eyebrow mb-4">Why it works</p>
        <h2 class="text-h2">An audit that fixes things</h2>
      </div>
      <div class="mx-auto mt-8 max-w-2xl space-y-5 text-lg leading-relaxed text-slate-600">
        <p>
          Most cloud audits end with a PDF and a handshake. The Blueprint doesn't. We
          audit your AWS accounts against the Well-Architected Framework, then apply
          the cost-saving changes and remediate high-risk security findings during the
          engagement itself.
        </p>
        <p>
          Misconfigured infrastructure is one of the leading causes of data breaches,
          and most AWS estates carry waste that nobody has had time to chase down.
          Two weeks of focused work usually sorts the worst of both.
        </p>
        <ul class="list-disc space-y-2 pl-6">
          <li>Complete infrastructure assessment by AWS-certified engineers</li>
          <li>Cost optimisation roadmap with tagging strategy and budget alerts, targeting 25%+ reduction</li>
          <li>Critical security issues fixed during the review, not just listed</li>
          <li>No upfront cost and no long-term commitment</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-site max-w-4xl">
      <div class="text-center">
        <p class="eyebrow mb-4">What we look at</p>
        <h2 class="text-h2">The levers that actually move the bill</h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-slate-600">
          Cost optimisation isn't one big switch. It's a set of changes, most of them
          operational rather than code, that compound. Here's the ground we cover.
        </p>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-2">
        <div class="card h-full">
          <h3 class="text-lg font-semibold text-slate-900">Cost</h3>
          <ul class="mt-4 space-y-2.5">
            {costLevers.map((item) => (
              <li class="flex items-start gap-2.5 text-[0.95rem] leading-relaxed text-slate-600">
                <svg class="mt-1 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="card h-full">
          <h3 class="text-lg font-semibold text-slate-900">Security</h3>
          <ul class="mt-4 space-y-2.5">
            {securityLevers.map((item) => (
              <li class="flex items-start gap-2.5 text-[0.95rem] leading-relaxed text-slate-600">
                <svg class="mt-1 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section border-t border-slate-200 bg-slate-50">
    <div class="container-site">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-4">How it runs</p>
        <h2 class="text-h2">Two weeks, then the report</h2>
      </div>
      <ol class="mx-auto mt-14 grid max-w-4xl grid-cols-1 gap-6 md:grid-cols-3" data-reveal>
        {timelineSteps.map((step) => (
          <li class="card h-full">
            <span class="font-mono text-sm font-medium text-accent">{step.week}</span>
            <h3 class="mt-3 text-lg font-semibold text-slate-900">{step.title}</h3>
            <ul class="mt-3 space-y-2">
              {step.items.map((item) => (
                <li class="flex items-start gap-2.5 text-[0.95rem] leading-relaxed text-slate-600">
                  <svg class="mt-1 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6L9 17l-5-5" />
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section bg-white">
    <div class="container-site max-w-4xl">
      <div class="grid grid-cols-1 gap-10 md:grid-cols-2">
        <div>
          <p class="eyebrow mb-4">What we need from you</p>
          <h2 class="text-h2">Light touch on your team</h2>
          <p class="mt-4 text-lg leading-relaxed text-slate-600">
            The Blueprint is designed to run without tying up your engineers. To get started we need:
          </p>
          <ul class="mt-5 space-y-2.5">
            {requirements.map((item) => (
              <li class="flex items-start gap-2.5 text-[0.95rem] leading-relaxed text-slate-600">
                <svg class="mt-1 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="card h-full bg-slate-50">
          <p class="eyebrow mb-3">Proof</p>
          <p class="text-lg leading-relaxed text-slate-700">
            Across 20+ reviews we've found an average of <strong class="font-semibold text-slate-900">30% in potential savings</strong> —
            and because of the guarantee, finding less than 25% means you pay nothing.
          </p>
          <p class="mt-4 text-[0.95rem] leading-relaxed text-slate-600">
            Acorn, a HealthTech platform building for the NHS, came to us cost-conscious and
            running on expensive EC2. We redesigned the architecture to move them off it while
            meeting NHS DSPT security standards.
          </p>
          <a href="/case-studies/acorn-healthtech-compliance" class="mt-5 inline-flex items-center gap-2 font-medium text-accent no-underline hover:underline">
            Read the Acorn case study
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </a>
        </div>
      </div>

      <div class="mt-12 border-t border-slate-200 pt-8">
        <p class="eyebrow mb-4">Related reading</p>
        <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          {relatedPosts.map((post) => (
            <li>
              <a href={post.href} class="flex items-center justify-between gap-3 rounded-xl border border-slate-200 bg-white px-5 py-4 font-medium text-slate-800 no-underline transition-colors duration-fast hover:border-slate-300 hover:bg-slate-50">
                {post.title}
                <svg class="h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M5 12h14M13 6l6 6-6 6" />
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <FAQSection framed />

  <ClosingCTA
    title="Ready for quick cost and security wins?"
    subtitle="Book a free call and we'll tell you what a Blueprint would likely find in your estate."
    calendly={CTA_LINK}
  />
</BaseLayout>
