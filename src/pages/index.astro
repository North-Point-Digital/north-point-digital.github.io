---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import LogoWall from '../components/LogoWall.astro';
import AIExamplesSection from '../components/AIExamplesSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import HowWeWork from '../components/HowWeWork.astro';
import CaseStudySection from '../components/CaseStudySection.astro';
import AboutSection from '../components/AboutSection.astro';
import TeamSection from '../components/TeamSection.astro';
import FAQSection from '../components/FAQSection.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
import { buildFaqJsonLd } from '../data/faqs';

const teamMembers = [
  { name: "David Turnbull", role: "Founder & AWS Solutions Architect", bio: "10+ years of enterprise cloud expertise, specialising in AWS cost optimisation and security.", image: "/team/david-turnbull.png" },
  { name: "Mark Bridgett", role: "Principal AWS Solutions Architect", bio: "15+ years of enterprise cloud expertise, specialising in blockchain and web3 infrastructure.", image: "/team/mark-bridgett.png" },
  { name: "Ross Haselhurst", role: "Head of Business Development", bio: "10+ years experience in the technology industry, specialising in business development and sales.", image: "/team/ross-haselhurst.jpeg" },
  { name: "Krystian Nowak", role: "Senior Software Engineer", bio: "10+ years experience in the technology industry, specialising in software engineering and development.", image: "/team/krystian-nowak.jpeg" },
  { name: "Sarah Turnbull", role: "Head of Delivery", bio: "10+ years experience in the technology industry, specialising in delivery and project management.", image: "/team/sarah-turnbull.jpeg" },
];

const logos = [
  '/logos/client1-logo.jpeg', '/logos/client2-logo.png', '/logos/client3-logo.png',
  '/logos/client4-logo.svg', '/logos/client5-logo.png', '/logos/client6-logo.webp',
  '/logos/client7-logo.png', '/logos/client8-logo.png', '/logos/client9-logo.jpeg',
  '/logos/client10-logo.jpeg', '/logos/client11-logo.jpeg',
];
---

<BaseLayout
  title="AI Consultancy for UK Small Businesses | North Point Digital"
  description="Working AI for your business in six weeks, fixed fee, wherever your systems live. AWS partners for AI adoption, cost optimisation, and cloud done properly."
  canonical="https://northpointdigital.com/"
  jsonLd={[
    { "@context": "https://schema.org", "@type": "Organization", name: "North Point Digital", url: "https://northpointdigital.com/", logo: "https://northpointdigital.com/north-point-logo.webp", sameAs: ["https://www.linkedin.com/company/north-point-digital-ai/", "https://x.com/n0rth_p0int"], contactPoint: { "@type": "ContactPoint", email: "contact@northpointdigital.com", contactType: "sales" } },
    { "@context": "https://schema.org", "@type": "WebSite", name: "North Point Digital", url: "https://northpointdigital.com/" },
    { "@context": "https://schema.org", "@type": "ProfessionalService", name: "North Point Digital", url: "https://northpointdigital.com/", description: "We help small businesses put AI to work with fixed-fee proofs of concept, whatever their current systems, plus AWS cost optimisation, security and cloud platforms.", email: "contact@northpointdigital.com", areaServed: { "@type": "Country", name: "United Kingdom" }, priceRange: "$$", image: "https://northpointdigital.com/north-point-logo.webp", knowsAbout: ["AI adoption", "Artificial intelligence for small business", "AWS", "Cloud cost optimisation", "Cloud migration", "Well-Architected Reviews"] },
    buildFaqJsonLd(),
  ]}
>
  <HeroSection />
  <LogoWall logos={logos} invertLogos={['/logos/client4-logo.svg']} />
  <AIExamplesSection />
  <ServicesSection />
  <HowWeWork />
  <CaseStudySection />
  <AboutSection />
  <TeamSection teamMembers={teamMembers} />
  <FAQSection />
  <ClosingCTA />
</BaseLayout>
