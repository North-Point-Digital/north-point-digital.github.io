---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import ClosingCTA from '../../components/ClosingCTA.astro';

export async function getStaticPaths() {
  const studies = await getCollection('caseStudies');
  return studies.map((study) => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
const data = study.data;
const siteUrl = 'https://northpointdigital.com';

const description = data.pageSubtitle || data.executiveSummary || data.detailedChallenge || data.challenge;
const canonical = `${siteUrl}/case-studies/${study.slug}`;
const datePublished = data.publishDate;
const dateModified = data.lastUpdated || data.publishDate;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: data.pageTitle || data.clientName,
  name: data.clientName,
  description,
  url: canonical,
  industry: data.industry,
  image: data.logo ? `${siteUrl}${data.logo}` : `${siteUrl}/north-point-logo.webp`,
  ...(datePublished ? { datePublished } : {}),
  ...(dateModified ? { dateModified } : {}),
  author: { "@type": "Organization", name: "North Point Digital", url: siteUrl },
  publisher: { "@type": "Organization", name: "North Point Digital", logo: { "@type": "ImageObject", url: `${siteUrl}/north-point-logo.webp`, width: 1024, height: 1024 } },
  mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
  ...(data.testimonial ? {
    review: {
      "@type": "Review",
      reviewBody: data.testimonial.quote,
      author: { "@type": "Person", name: data.testimonial.author, ...(data.testimonial.role ? { jobTitle: data.testimonial.role } : {}) },
      itemReviewed: { "@type": "Organization", name: "North Point Digital", url: siteUrl },
    },
  } : {}),
};
const breadcrumbs = [
  { name: 'Home', url: siteUrl },
  { name: data.clientName, url: canonical },
];

const sections = [
  data.executiveSummary && { title: 'Executive summary', body: data.executiveSummary },
  { title: 'The challenge', body: data.detailedChallenge || data.challenge },
  data.whyChooseUs && { title: 'Why North Point Digital', body: data.whyChooseUs },
].filter(Boolean);
---

<BaseLayout title={`${data.pageTitle || data.clientName} | Case Study | North Point Digital`} description={description} canonical={canonical} jsonLd={jsonLd} breadcrumbs={breadcrumbs}>
  <article class="bg-white pt-16">
    <div class="container-site max-w-4xl py-16">
      <a href="/#case-studies" class="inline-flex items-center gap-2 text-sm font-medium text-slate-500 no-underline transition-colors duration-fast hover:text-slate-900">
        ← Back to case studies
      </a>

      <header class="mt-8 flex flex-col items-start gap-6 sm:flex-row sm:items-center">
        {data.logo && (
          <img
            src={data.logo}
            alt={`${data.clientName} logo`}
            width="88"
            height="88"
            class="h-20 w-20 rounded-xl border border-slate-200 bg-white object-contain p-3"
          />
        )}
        <div>
          <h1 class="text-[clamp(1.875rem,3.5vw,2.5rem)] font-semibold leading-tight tracking-tight text-slate-900">
            {data.pageTitle || data.clientName}
          </h1>
          {data.industry && <p class="mt-2 text-lg text-slate-500">{data.industry}</p>}
        </div>
      </header>

      {(data.pageSubtitle || data.challenge) && (
        <p class="mt-6 text-lg leading-relaxed text-slate-600">
          {data.pageSubtitle || data.challenge}
        </p>
      )}

      <div class="mt-12 space-y-12">
        {sections.map((section) => (
          <section>
            <h2 class="text-2xl font-semibold tracking-tight text-slate-900">{section.title}</h2>
            <div class="mt-4 whitespace-pre-line text-lg leading-relaxed text-slate-600">{section.body}</div>
          </section>
        ))}

        <section>
          <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Our solution</h2>
          <div class="mt-4 whitespace-pre-line text-lg leading-relaxed text-slate-600">{data.detailedSolution || data.solution}</div>
          {data.technologies && data.technologies.length > 0 && (
            <div class="mt-8">
              <h3 class="text-lg font-semibold text-slate-900">Technologies used</h3>
              <ul class="mt-4 flex flex-wrap gap-2">
                {data.technologies.map((tech) => (
                  <li class="rounded-lg border border-slate-200 bg-slate-50 px-3 py-1.5 font-mono text-sm text-slate-700">{tech}</li>
                ))}
              </ul>
            </div>
          )}
        </section>

        {data.metrics && data.metrics.length > 0 && (
          <section>
            <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Key metrics</h2>
            <dl class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {data.metrics.map((metric) => (
                <div class="card !p-6 text-center">
                  <dd class="font-mono text-3xl font-semibold tracking-tight text-slate-900">{metric.value}</dd>
                  <dt class="mt-1 text-sm text-slate-600">{metric.label}</dt>
                </div>
              ))}
            </dl>
          </section>
        )}

        <section>
          <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Results</h2>
          <ul class="mt-5 space-y-3">
            {data.results.map((result) => (
              <li class="flex items-start gap-3 text-lg leading-relaxed text-slate-600">
                <svg class="mt-1.5 h-4 w-4 shrink-0 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 6L9 17l-5-5" />
                </svg>
                {result}
              </li>
            ))}
          </ul>
        </section>

        {data.testimonial && (
          <section class="rounded-2xl border border-slate-200 bg-slate-50 p-8 md:p-10">
            <blockquote class="text-xl leading-relaxed text-slate-700">
              “{data.testimonial.quote}”
            </blockquote>
            <p class="mt-5 font-semibold text-slate-900">
              {data.testimonial.author}<span class="font-normal text-slate-500">{data.testimonial.role && `, ${data.testimonial.role}`}</span>
            </p>
          </section>
        )}

        {data.timeline && (
          <section>
            <h2 class="text-2xl font-semibold tracking-tight text-slate-900">Timeline</h2>
            <p class="mt-4 text-lg leading-relaxed text-slate-600">{data.timeline}</p>
          </section>
        )}
      </div>
    </div>
  </article>

  <ClosingCTA
    title="Facing something similar?"
    subtitle="Book a free 30-minute call and we'll talk through how we'd approach it."
  />
</BaseLayout>
