---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const siteUrl = 'https://northpointdigital.com';
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime()
);

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'AWS & Cloud Strategy Blog',
  description: 'Articles on AWS cost optimisation, landing zones, and cloud strategy from North Point Digital.',
  url: `${siteUrl}/blog`,
  publisher: { '@type': 'Organization', name: 'North Point Digital', logo: { '@type': 'ImageObject', url: `${siteUrl}/north-point-logo.webp` } },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: posts.map((post, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `${siteUrl}/blog/${post.slug}`,
      name: post.data.title,
    })),
  },
};
---

<BaseLayout
  title="AWS & Cloud Strategy Blog | North Point Digital"
  description="Articles on AWS cost optimisation, landing zones, and cloud strategy from North Point Digital."
  canonical="https://northpointdigital.com/blog"
  breadcrumbs={[{ name: 'Home', url: siteUrl }, { name: 'Blog', url: `${siteUrl}/blog` }]}
  jsonLd={blogJsonLd}
>
  <section class="relative overflow-hidden bg-white pt-16">
    <div class="hero-tint" aria-hidden="true"></div>
    <div class="hero-dots" aria-hidden="true"></div>
    <div class="container-site relative py-20 md:py-24">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow mb-6">Blog</p>
        <h1 class="text-h1">Notes from the field</h1>
        <p class="mt-6 text-lg leading-relaxed text-slate-600 md:text-xl">
          Practical articles on AWS cost optimisation, landing zones and cloud
          architecture — for people who'd rather have specifics than buzzwords.
        </p>
      </div>

      <div class="mx-auto mt-14 grid max-w-5xl grid-cols-1 gap-6 md:grid-cols-2">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="card card-hover group flex h-full flex-col overflow-hidden !p-0 no-underline">
            {post.data.thumbnailImage && (
              <img
                src={post.data.thumbnailImage}
                alt=""
                loading="lazy"
                width="600"
                height="200"
                class="h-[200px] w-full border-b border-slate-200 object-cover"
              />
            )}
            <div class="flex flex-1 flex-col p-8">
              <p class="text-sm text-slate-500">
                {new Date(post.data.publishDate).toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}
                {' · '}
                {post.data.author}
              </p>
              <h2 class="mt-2 text-xl font-semibold text-slate-900">{post.data.title}</h2>
              {post.data.excerpt && (
                <p class="mt-3 leading-relaxed text-slate-600">{post.data.excerpt}</p>
              )}
              <span class="mt-auto pt-6 font-semibold text-accent transition-colors duration-fast group-hover:text-accent-hover">
                Read the article →
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="mx-auto mt-14 max-w-5xl rounded-2xl border border-accent/30 bg-gradient-to-b from-accent-tint/60 to-white p-8 text-center md:p-10">
        <p class="eyebrow mb-3">Free download</p>
        <h2 class="text-2xl font-semibold tracking-tight text-slate-900">The AI Adoption Playbook</h2>
        <p class="mx-auto mt-3 max-w-xl text-slate-600">
          If you're reading up before making a move, start here — picking a use case,
          getting your data ready, and what AI actually costs to run.
        </p>
        <a href="/ai-adoption-playbook" class="btn-primary mt-6" data-track-cta="Blog Index Playbook">
          Get the playbook
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
