---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { slugifyCategory } from '../../utils/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const siteUrl = 'https://northpointdigital.com';
const description = post.data.metaDescription || post.data.excerpt || `${post.data.title} from North Point Digital.`;
const canonical = `${siteUrl}/blog/${post.slug}`;
const ogImage = post.data.ogImage || post.data.featuredImage || post.data.thumbnailImage || `${siteUrl}/north-point-logo.webp`;
const publishDate = post.data.publishDate;
const modifiedDate = post.data.lastUpdated || post.data.publishDate;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  url: canonical,
  headline: post.data.title,
  description,
  image: ogImage,
  author: {
    '@type': 'Person',
    name: post.data.author,
    ...(post.data.authorRole ? { jobTitle: post.data.authorRole } : {}),
    worksFor: { '@type': 'Organization', name: 'North Point Digital', url: siteUrl },
  },
  publisher: { '@type': 'Organization', name: 'North Point Digital', logo: { '@type': 'ImageObject', url: `${siteUrl}/north-point-logo.webp`, width: 1024, height: 1024 } },
  datePublished: publishDate,
  dateModified: modifiedDate,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  wordCount: post.body?.split(/\s+/).length || 0,
};

const breadcrumbs = [
  { name: 'Home', url: siteUrl },
  { name: 'Blog', url: `${siteUrl}/blog` },
  { name: post.data.title, url: canonical },
];
---

<BaseLayout title={`${post.data.title} | Blog | North Point Digital`} description={description} canonical={canonical} jsonLd={jsonLd} ogImage={ogImage} breadcrumbs={breadcrumbs} ogType="article" publishDate={publishDate} modifiedDate={modifiedDate}>
  <article class="bg-white pt-16">
    <div class="mx-auto max-w-3xl px-6 py-16 md:px-8">
      <a href="/blog" class="inline-flex items-center gap-2 text-sm font-medium text-slate-500 no-underline transition-colors duration-fast hover:text-slate-900">
        ← Back to the blog
      </a>
      <h1 class="mt-6 text-[clamp(2rem,4vw,2.75rem)] font-semibold leading-[1.15] tracking-tight text-slate-900">{post.data.title}</h1>
      <p class="mt-4 text-[0.95rem] text-slate-500">
        <a
          href={`/blog/category/${slugifyCategory(post.data.category)}`}
          class="font-medium text-accent no-underline hover:underline"
        >
          {post.data.category}
        </a>
        {' · '}
        {new Date(post.data.publishDate).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
        {' · '}
        {post.data.author}
        {post.data.authorRole ? `, ${post.data.authorRole}` : ''}
      </p>
      {post.data.featuredImage && (
        <img
          src={post.data.featuredImage}
          alt={post.data.title}
          loading="eager"
          class="mt-8 max-h-[480px] w-full rounded-2xl border border-slate-200 object-cover"
        />
      )}
      <div
        data-article-content
        class="prose prose-slate mt-10 max-w-none prose-headings:font-semibold prose-headings:tracking-tight prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-code:rounded prose-code:bg-slate-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:font-mono prose-code:text-[0.9em] prose-code:before:content-none prose-code:after:content-none [&_.callout]:my-8 [&_.callout]:rounded-xl [&_.callout]:border [&_.callout]:border-amber-200 [&_.callout]:bg-amber-50 [&_.callout]:p-6 [&_.callout-title]:mb-2 [&_.callout-title]:block [&_.callout-title]:text-lg [&_.callout-title]:font-semibold [&_.callout-title]:text-slate-900 [&_blockquote]:rounded-xl [&_blockquote]:border-l-4 [&_blockquote]:border-amber-300 [&_blockquote]:bg-amber-50 [&_blockquote]:px-6 [&_blockquote]:py-4 [&_blockquote]:not-italic"
      >
        <Content />
      </div>

      <div class="mt-14 rounded-2xl border border-slate-200 bg-slate-50 p-8 text-center">
        <h2 class="text-xl font-semibold text-slate-900">Want a second pair of eyes on your AWS estate?</h2>
        <p class="mx-auto mt-2 max-w-md text-slate-600">A free 30-minute call with an engineer. No pitch deck.</p>
        <a
          href="https://calendly.com/david-northpointdigital/north-point-digital-initial-call"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary mt-6"
          data-track-cta="Blog Post Book a Call"
        >
          Book a free call
        </a>
      </div>
    </div>
  </article>
</BaseLayout>

<script is:inline>
  (function() {
    var g = typeof window.gtag === 'function' ? window.gtag : null;
    if (!g) return;

    var article = document.querySelector('[data-article-content]');
    if (!article) return;

    var articleTitle = document.title;
    var readStart = Date.now();
    var readMarks = [30, 60, 120, 180];
    var readIdx = 0;

    var readCheck = setInterval(function() {
      if (readIdx >= readMarks.length) { clearInterval(readCheck); return; }
      var elapsed = Math.floor((Date.now() - readStart) / 1000);
      if (elapsed >= readMarks[readIdx]) {
        g('event', 'article_read_time', {
          event_category: 'blog_engagement',
          event_label: readMarks[readIdx] + 's',
          article_title: articleTitle,
          time_seconds: readMarks[readIdx],
        });
        readIdx++;
      }
    }, 5000);

    var artDepthFired = {};
    var artMarks = [25, 50, 75, 100];
    function checkArticleScroll() {
      var rect = article.getBoundingClientRect();
      var artHeight = article.scrollHeight || article.offsetHeight;
      var viewBottom = window.innerHeight;
      var scrolled = viewBottom - rect.top;
      if (artHeight <= 0 || scrolled < 0) return;
      var pct = Math.min(Math.round((scrolled / artHeight) * 100), 100);
      artMarks.forEach(function(mark) {
        if (pct >= mark && !artDepthFired[mark]) {
          artDepthFired[mark] = true;
          g('event', 'article_scroll_depth', {
            event_category: 'blog_engagement',
            event_label: mark + '%',
            article_title: articleTitle,
            scroll_depth: mark,
          });
        }
      });
    }
    var artTimer;
    window.addEventListener('scroll', function() {
      clearTimeout(artTimer);
      artTimer = setTimeout(checkArticleScroll, 150);
    }, { passive: true });

    window.addEventListener('beforeunload', function() {
      var totalTime = Math.floor((Date.now() - readStart) / 1000);
      if (totalTime > 5 && navigator.sendBeacon) {
        navigator.sendBeacon(
          'https://www.google-analytics.com/g/collect?v=2&tid=G-CX6XEZX2R0&cid=' + (document.cookie.match(/_ga=GA\d+\.\d+\.(\d+\.\d+)/) || ['','0.0'])[1],
          ''
        );
      }
    });
  })();
</script>
