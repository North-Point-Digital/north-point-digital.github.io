---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import BlogIndex from '../../../../components/BlogIndex.astro';
import { sortByDate, uniqueCategories, slugifyCategory, POSTS_PER_PAGE } from '../../../../utils/blog';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = sortByDate(await getCollection('blog'));
  const categories = uniqueCategories(posts);
  return categories.flatMap((category) =>
    paginate(
      posts.filter((post) => slugifyCategory(post.data.category) === category.slug),
      { params: { category: category.slug }, pageSize: POSTS_PER_PAGE }
    )
  );
};

const { page } = Astro.props;
const { category } = Astro.params;

const allPosts = sortByDate(await getCollection('blog'));
const categories = uniqueCategories(allPosts);
const categoryName = categories.find((c) => c.slug === category)?.name ?? category;

const siteUrl = 'https://northpointdigital.com';
const pageSuffix = page.currentPage > 1 ? ` – Page ${page.currentPage}` : '';
const description = `Articles on ${categoryName} from North Point Digital — practical guidance, no buzzwords.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${categoryName} articles`,
  description,
  url: `${siteUrl}${page.url.current}`,
  publisher: { '@type': 'Organization', name: 'North Point Digital', logo: { '@type': 'ImageObject', url: `${siteUrl}/north-point-logo.webp` } },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: page.data.map((post, i) => ({
      '@type': 'ListItem',
      position: page.start + i + 1,
      url: `${siteUrl}/blog/${post.slug}`,
      name: post.data.title,
    })),
  },
};
---

<BaseLayout
  title={`${categoryName} Articles${pageSuffix} | Blog | North Point Digital`}
  description={description}
  canonical={`${siteUrl}${page.url.current}`}
  breadcrumbs={[
    { name: 'Home', url: siteUrl },
    { name: 'Blog', url: `${siteUrl}/blog` },
    { name: categoryName, url: `${siteUrl}/blog/category/${category}` },
  ]}
  jsonLd={jsonLd}
>
  <BlogIndex page={page} categories={categories} activeCategory={category} />
</BaseLayout>
